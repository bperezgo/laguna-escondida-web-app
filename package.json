{
  "name": "laguna-escondida-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "site",
    "funnels/*",
    "studio"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=site",
    "dev:funnel:celebraciones": "npm run dev --workspace=funnels/celebraciones",
    "dev:studio": "npm run dev --workspace=studio",
    "build": "node build.mjs",
    "build:site": "npm run build --workspace=site",
    "build:funnel:celebraciones": "npm run build --workspace=funnels/celebraciones",
    "build:studio": "npm run build --workspace=studio"
  }
}
