---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Button from '../../components/ui/Button.astro';
import menuData from '../../../../menu.json';

const { restaurant, categories } = menuData;
type Dish = { id: string; name: string; description: string; price: number; image?: string };
type Category = { id: string; name: string; order: number; dishes: Dish[] };
const sortedCategories = ([...categories].sort((a, b) => a.order - b.order)) as Category[];

const formatPrice = (price: number): string =>
  '$' + price.toLocaleString('es-CO');

const waNumber = '573194313781';
const waMessage = 'Hola, quiero reservar una mesa en el restaurante de Laguna Escondida';
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;
---

<BaseLayout
  title="Menú del Restaurante — Laguna Escondida | Marinilla, Antioquia"
  description="Conoce el menú de Laguna Escondida: tilapia, yamu, trucha, picadas, sopas y bebidas. Restaurante campestre con vista al lago en Marinilla, Antioquia."
>
  <Navbar />

  <header class="menu-hero" data-section="menu-hero" data-screen-label="Menú hero">
    <div class="hero-container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <span class="is-current">Menú</span>
      </nav>

      <div class="hero-content">
        <Eyebrow text="Carta · Cocina campestre" inverse />
        <h1 class="hero-title">
          {restaurant.name}
        </h1>
        <p class="hero-lead">{restaurant.tagline}</p>
      </div>
    </div>
  </header>

  <div id="category-tabs" class="category-tabs">
    <div class="tabs-container">
      <div class="tabs-scroll" role="tablist" aria-label="Categorías del menú">
        {sortedCategories.map((cat, i) => (
          <button
            role="tab"
            data-target={cat.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class:list={['tab-btn', i === 0 && 'is-active']}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </div>
  </div>

  <main class="menu-main">
    <div class="menu-container">
      {sortedCategories.map((cat, i) => (
        <section id={cat.id} data-section={`menu-${cat.id}`} class="menu-category">
          <header class="category-head">
            <p class="category-index">{String(i + 1).padStart(2, '0')}</p>
            <h2 class="category-title">{cat.name}</h2>
          </header>

          <ul class="dishes-list">
            {cat.dishes.map((dish) => (
              <li class="dish-item">
                {dish.image && (
                  <div class="dish-media">
                    <img src={dish.image} alt={dish.name} width="128" height="128" loading="lazy" />
                  </div>
                )}
                <div class="dish-body">
                  <div class="dish-head">
                    <h3 class="dish-name">{dish.name}</h3>
                    <span class="dish-dots" aria-hidden="true"></span>
                    <span class="dish-price">{formatPrice(dish.price)}</span>
                  </div>
                  {dish.description && (
                    <p class="dish-desc">{dish.description}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>

          {i < sortedCategories.length - 1 && <div class="category-divider" aria-hidden="true"></div>}
        </section>
      ))}

      <div class="menu-cta">
        <Eyebrow text="Reservas" centered />
        <h2 class="cta-title">¿Listo para reservar?</h2>
        <p class="cta-lead">
          Contáctanos por WhatsApp para reservar tu mesa o consultar disponibilidad.
        </p>
        <Button
          variant="primary"
          href={waHref}
          event="whatsapp_click"
          location="menu-cta"
          target="_blank"
          rel="noopener"
          withDot
        >
          Reservar mesa
        </Button>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .menu-hero {
    position: relative;
    padding-block: clamp(96px, 10vw, 140px) clamp(48px, 6vw, 80px);
    background: var(--color-lake-800);
    color: var(--color-sand-50);
  }

  .hero-container {
    max-width: 820px;
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .breadcrumb {
    display: flex;
    gap: 10px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.55);
    margin-bottom: 40px;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-3, 200ms) var(--ease-out);
  }

  .breadcrumb a:hover {
    color: var(--color-sand-50);
  }

  .breadcrumb .is-current {
    color: var(--color-earth-300);
  }

  .hero-content {
    display: grid;
    gap: 16px;
    text-align: center;
    justify-items: center;
  }

  .hero-title {
    margin: 12px 0 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-sand-50);
  }

  .hero-lead {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.78);
    max-width: 48ch;
  }

  .category-tabs {
    position: sticky;
    top: 64px;
    z-index: 40;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
  }

  .tabs-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .tabs-scroll {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-block: 16px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .tabs-scroll::-webkit-scrollbar {
    display: none;
  }

  .tab-btn {
    flex-shrink: 0;
    padding: 8px 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    cursor: pointer;
    transition: all var(--duration-3, 200ms) var(--ease-out);
  }

  .tab-btn:hover {
    color: var(--color-ink);
    border-color: var(--color-earth-300);
  }

  .tab-btn.is-active {
    color: var(--color-sand-50);
    background: var(--color-lake-700);
    border-color: var(--color-lake-700);
  }

  .menu-main {
    background: var(--color-surface);
    padding-block: clamp(48px, 6vw, 80px) clamp(80px, 10vw, 140px);
  }

  .menu-container {
    max-width: 820px;
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .menu-category {
    scroll-margin-top: 160px;
    padding-top: 56px;
  }

  .menu-category:first-of-type {
    padding-top: 32px;
  }

  .category-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-line-gold, var(--color-earth-300));
  }

  .category-index {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-ink, var(--color-earth-400));
  }

  .category-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    line-height: 1.1;
    color: var(--color-ink);
  }

  .dishes-list {
    margin: 32px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .dish-item {
    display: flex;
    gap: 20px;
    padding-block: 24px;
    border-bottom: 1px solid var(--color-line);
  }

  .dish-item:last-child {
    border-bottom: none;
  }

  .dish-media {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    overflow: hidden;
    background: var(--color-surface-tint);
  }

  .dish-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dish-body {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 8px;
  }

  .dish-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .dish-name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--color-ink);
    flex-shrink: 0;
  }

  .dish-dots {
    flex: 1;
    height: 1px;
    min-width: 24px;
    background-image: radial-gradient(circle, var(--color-line) 1px, transparent 1px);
    background-size: 6px 2px;
    background-repeat: repeat-x;
    background-position: 0 50%;
    align-self: center;
    margin-top: 4px;
  }

  .dish-price {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-lake-700);
    flex-shrink: 0;
  }

  .dish-desc {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-sm);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 56ch;
  }

  .category-divider {
    margin: 48px 0 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--color-earth-300) 35%, transparent),
      transparent
    );
  }

  .menu-cta {
    margin-top: 80px;
    padding-top: 56px;
    border-top: 1px solid var(--color-line);
    display: grid;
    justify-items: center;
    gap: 16px;
    text-align: center;
  }

  .cta-title {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.1;
    color: var(--color-ink);
  }

  .cta-lead {
    margin: 0 0 16px;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 42ch;
  }

  @media (max-width: 560px) {
    .dish-item {
      flex-direction: column;
      gap: 16px;
    }

    .dish-media {
      width: 100%;
      height: 200px;
    }

    .dish-head {
      flex-wrap: wrap;
    }

    .dish-dots {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var tabs = document.querySelectorAll('.tab-btn');
    var sections = document.querySelectorAll('main section[id]');

    function setActive(id) {
      tabs.forEach(function (btn) {
        var isActive = btn.getAttribute('data-target') === id;
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
        btn.classList.toggle('is-active', isActive);
        if (isActive) {
          btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
        }
      });
    }

    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-target');
        var section = document.getElementById(targetId);
        if (section) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        setActive(targetId);
      });
    });

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      { threshold: 0.25, rootMargin: '-160px 0px -55% 0px' }
    );

    sections.forEach(function (section) {
      observer.observe(section);
    });
  })();
</script>
