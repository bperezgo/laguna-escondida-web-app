---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import menuData from '../../../../menu.json';

const { restaurant, categories } = menuData;
const sortedCategories = [...categories].sort((a, b) => a.order - b.order);

const formatPrice = (price: number): string =>
  '$' + price.toLocaleString('es-CO');

const waNumber = '573194313781';
const waMessage = 'Hola, quiero reservar una mesa en el restaurante de Laguna Escondida';
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;
---

<BaseLayout
  title="Menú del Restaurante — Laguna Escondida | Marinilla, Antioquia"
  description="Conoce el menú de Laguna Escondida: tilapia, yamu, trucha, picadas, sopas y bebidas. Restaurante campestre con vista al lago en Marinilla, Antioquia."
>
  <Navbar />

  <!-- ── HEADER ───────────────────────────────────────────────── -->
  <header class="bg-lake-700 py-10 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <img
        src="/logo-navbar.png"
        alt="Laguna Escondida"
        width="72"
        height="72"
        class="rounded-full mx-auto mb-5 ring-2 ring-earth-300/40"
        loading="eager"
      />
      <h1 class="font-display text-3xl sm:text-4xl text-white mb-2">{restaurant.name}</h1>
      <p class="font-body text-earth-300 text-base">{restaurant.tagline}</p>
    </div>
  </header>

  <!-- ── TABS STICKY ──────────────────────────────────────────── -->
  <div id="category-tabs" class="sticky top-[64px] z-40 bg-sand-100 border-b border-sand-200 shadow-sm">
    <div class="max-w-3xl mx-auto px-4">
      <div class="tabs-scroll flex overflow-x-auto gap-2 py-3" role="tablist" aria-label="Categorías del menú">
        {sortedCategories.map((cat, i) => (
          <button
            role="tab"
            data-target={cat.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class:list={[
              'tab-btn flex-shrink-0 px-4 py-2 rounded-full font-body text-sm font-semibold transition-all duration-200 border cursor-pointer',
              i === 0
                ? 'bg-lake-500 text-white border-lake-500'
                : 'bg-white text-lake-700 border-sand-200 hover:border-lake-100 hover:bg-lake-50'
            ]}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── MENU CONTENT ─────────────────────────────────────────── -->
  <main class="bg-sand-gradient min-h-screen">
    <div class="max-w-3xl mx-auto px-4 pt-4 pb-16">

      {sortedCategories.map((cat, i) => (
        <section id={cat.id} data-section={`menu-${cat.id}`} class="scroll-mt-36">
          <h2 class="font-display text-xl sm:text-2xl text-lake-700 pt-8 mb-5">
            {cat.name}
          </h2>

          <div class="space-y-3">
            {cat.dishes.map((dish) => (
              <div class="card-standard p-0 overflow-hidden">
                <div class="flex items-stretch gap-0">
                  <!-- Texto -->
                  <div class="flex-1 min-w-0 flex flex-col justify-between p-4 sm:p-5">
                    <div>
                      <h3 class="font-display text-base text-lake-700 leading-snug">{dish.name}</h3>
                      {dish.description && (
                        <p class="font-body text-sm text-neutral/70 mt-1 leading-relaxed">{dish.description}</p>
                      )}
                    </div>
                    <span class="font-body font-semibold text-earth-500 text-base mt-3 block">
                      {formatPrice(dish.price)}
                    </span>
                  </div>
                  <!-- Imagen -->
                  {dish.image && (
                    <div class="w-28 sm:w-32 shrink-0">
                      <img
                        src={dish.image}
                        alt={dish.name}
                        width="128"
                        height="128"
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>

          {i < sortedCategories.length - 1 && (
            <div class="mt-10 mb-2 h-px" style="background: linear-gradient(to right, transparent, #C9A84C55, transparent);"></div>
          )}
        </section>
      ))}

      <!-- ── CTA WHATSAPP ────────────────────────────────────── -->
      <div class="text-center pt-14 pb-4">
        <div class="h-px mb-8 mx-auto max-w-xs" style="background: linear-gradient(to right, transparent, #C9A84C, transparent);"></div>
        <h2 class="font-display text-2xl sm:text-3xl text-lake-700 mb-3">¿Listo para reservar?</h2>
        <p class="font-body text-neutral/70 mb-7 max-w-xs mx-auto text-sm sm:text-base">
          Contáctanos por WhatsApp para reservar tu mesa o consultar disponibilidad.
        </p>
        <a
          href={waHref}
          class="btn btn-primary text-white font-body font-semibold gap-2 px-6"
          data-event="whatsapp_click"
          data-location="menu-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Reservar mesa
        </a>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hide scrollbar on tabs row while keeping scroll */
  .tabs-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .tabs-scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    var tabs = document.querySelectorAll('.tab-btn');
    var sections = document.querySelectorAll('main section[id]');

    function setActive(id) {
      tabs.forEach(function (btn) {
        var isActive = btn.getAttribute('data-target') === id;
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');

        if (isActive) {
          btn.classList.add('bg-lake-500', 'text-white', 'border-lake-500');
          btn.classList.remove('bg-white', 'text-lake-700', 'border-sand-200');
        } else {
          btn.classList.remove('bg-lake-500', 'text-white', 'border-lake-500');
          btn.classList.add('bg-white', 'text-lake-700', 'border-sand-200');
        }

        // Scroll active tab into view in the tabs bar
        if (isActive) {
          btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
        }
      });
    }

    // Click → scroll to section
    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-target');
        var section = document.getElementById(targetId);
        if (section) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        setActive(targetId);
      });
    });

    // IntersectionObserver → update active tab on scroll
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      { threshold: 0.25, rootMargin: '-120px 0px -55% 0px' }
    );

    sections.forEach(function (section) {
      observer.observe(section);
    });
  })();
</script>
