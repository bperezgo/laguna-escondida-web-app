---
import BaseLayout from '../../layouts/BaseLayout.astro';
import menuData from '../../../../menu.json';

const { restaurant, categories } = menuData;
type Dish = { id: string; name: string; description: string; price: number; image?: string };
type Category = { id: string; name: string; order: number; dishes: Dish[] };
const sortedCategories = ([...categories].sort((a, b) => a.order - b.order)) as Category[];

const formatPrice = (price: number): string =>
  '$' + price.toLocaleString('es-CO');

---

<BaseLayout
  title="Menú del Restaurante — Laguna Escondida | Marinilla, Antioquia"
  description="Conoce el menú de Laguna Escondida: tilapia, yamu, trucha, picadas, sopas y bebidas. Restaurante campestre con vista al lago en Marinilla, Antioquia."
>
  <!-- ── HEADER ───────────────────────────────────────────────── -->
  <header class="bg-lake-700 py-10 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <img
        src="/logo-navbar.png"
        alt="Laguna Escondida"
        width="72"
        height="72"
        class="rounded-full mx-auto mb-5 ring-2 ring-earth-300/40"
        loading="eager"
      />
      <h1 class="font-display text-3xl sm:text-4xl text-white mb-2">{restaurant.name}</h1>
      <p class="font-body text-earth-300 text-base">{restaurant.tagline}</p>
    </div>
  </header>

  <!-- ── TABS STICKY ──────────────────────────────────────────── -->
  <div id="category-tabs" class="sticky top-0 z-40 bg-sand-100 border-b border-sand-200 shadow-sm">
    <div class="max-w-3xl mx-auto px-4">
      <div class="tabs-scroll flex overflow-x-auto gap-2 py-3" role="tablist" aria-label="Categorías del menú">
        {sortedCategories.map((cat, i) => (
          <button
            role="tab"
            data-target={cat.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            class:list={[
              'tab-btn shrink-0 px-4 py-2 rounded-full font-body text-sm font-semibold transition-all duration-200 border cursor-pointer',
              i === 0
                ? 'bg-lake-500 text-white border-lake-500'
                : 'bg-white text-lake-700 border-sand-200 hover:border-lake-100 hover:bg-lake-50'
            ]}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── MENU CONTENT ─────────────────────────────────────────── -->
  <main class="bg-sand-gradient min-h-screen">
    <div class="max-w-3xl mx-auto px-4 pt-4 pb-16">

      {sortedCategories.map((cat, i) => (
        <section id={cat.id} data-section={`menu-${cat.id}`} class="scroll-mt-20">
          <h2 class="font-display text-xl sm:text-2xl text-lake-700 pt-8 mb-5">
            {cat.name}
          </h2>

          <div class="space-y-3">
            {cat.dishes.map((dish) => (
              <div class="card-standard p-0 overflow-hidden">
                <div class="flex items-stretch gap-0">
                  <!-- Texto -->
                  <div class="flex-1 min-w-0 flex flex-col justify-between p-4 sm:p-5">
                    <div>
                      <h3 class="font-display text-base text-lake-700 leading-snug">{dish.name}</h3>
                      {dish.description && (
                        <p class="font-body text-sm text-neutral/70 mt-1 leading-relaxed">{dish.description}</p>
                      )}
                    </div>
                    <span class="font-body font-semibold text-earth-500 text-base mt-3 block">
                      {formatPrice(dish.price)}
                    </span>
                  </div>
                  <!-- Imagen -->
                  {dish.image && (
                    <div class="w-28 sm:w-32 shrink-0">
                      <img
                        src={dish.image}
                        alt={dish.name}
                        width="128"
                        height="128"
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>

          {i < sortedCategories.length - 1 && (
            <div class="mt-10 mb-2 h-px" style="background: linear-gradient(to right, transparent, #C9A84C55, transparent);"></div>
          )}
        </section>
      ))}

    </div>
  </main>
</BaseLayout>

<style>
  .tabs-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .tabs-scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    var tabs = document.querySelectorAll('.tab-btn');
    var sections = document.querySelectorAll('main section[id]');

    function setActive(id) {
      tabs.forEach(function (btn) {
        var isActive = btn.getAttribute('data-target') === id;
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');

        if (isActive) {
          btn.classList.add('bg-lake-500', 'text-white', 'border-lake-500');
          btn.classList.remove('bg-white', 'text-lake-700', 'border-sand-200');
        } else {
          btn.classList.remove('bg-lake-500', 'text-white', 'border-lake-500');
          btn.classList.add('bg-white', 'text-lake-700', 'border-sand-200');
        }

        if (isActive) {
          btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
        }
      });
    }

    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-target');
        var section = document.getElementById(targetId);
        if (section) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        setActive(targetId);
      });
    });

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      { threshold: 0.25, rootMargin: '-60px 0px -55% 0px' }
    );

    sections.forEach(function (section) {
      observer.observe(section);
    });
  })();
</script>
