---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import StarRating from '../../../components/StarRating.astro';

const waNumber = '573194313781';
const waMessage = 'Hola, quiero reservar una mesa en el restaurante de Laguna Escondida';
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

const platos = [
  {
    nombre: 'Yamu Frito Entero',
    descripcion: 'La estrella del lago. Servido entero, crujiente por fuera y jugoso por dentro. Con patacones y ensalada fresca.',
    badge: 'Plato estrella',
    badgeClass: 'bg-earth-300 text-lake-700',
    img: '/images/restaurante/yamu-frito.jpg',
    imgAlt: 'Yamu frito entero con patacones en Laguna Escondida',
  },
  {
    nombre: 'Tilapia a la Plancha',
    descripcion: 'Fresca del lago, preparada a la plancha con limón y hierbas de la región. Liviana y llena de sabor.',
    badge: 'Muy pedido',
    badgeClass: 'bg-lake-100 text-lake-700',
    img: '/images/restaurante/tilapia-plancha.jpg',
    imgAlt: 'Tilapia a la plancha en restaurante campestre Laguna Escondida',
  },
  {
    nombre: 'Cachama al Ajillo',
    descripcion: 'Receta de la casa. Cachama entera en salsa de ajo y mantequilla, acompañada de yuca frita y arroz.',
    badge: 'Receta de la casa',
    badgeClass: 'bg-sand-200 text-lake-700',
    img: '/images/restaurante/cachama-ajillo.jpg',
    imgAlt: 'Cachama al ajillo con yuca frita en Laguna Escondida',
  },
  {
    nombre: 'Trucha con Hierbas',
    descripcion: 'El clásico campestre. Trucha entera marinada en hierbas frescas, al horno con papas criollas.',
    badge: 'Clásico campestre',
    badgeClass: 'bg-lake-50 text-lake-700',
    img: '/images/restaurante/trucha-hierbas.jpg',
    imgAlt: 'Trucha con hierbas al horno en restaurante Laguna Escondida',
  },
];

const resenas = [
  {
    texto: 'El Yamu frito fue lo mejor que he comido en mucho tiempo. Nunca había probado nada así. El lugar es hermoso y la atención, excelente.',
    autor: 'Visitante de Google Maps',
    estrellas: 5,
  },
  {
    texto: 'Pescamos en la mañana y al mediodía nos prepararon el mismo pescado que habíamos sacado del lago. Una experiencia que no se olvida.',
    autor: 'Visitante de Google Maps',
    estrellas: 5,
  },
  {
    texto: 'La vista al lago mientras comes no tiene precio. Los patacones caseros y la Cachama al ajillo, una combinación perfecta.',
    autor: 'Visitante de Google Maps',
    estrellas: 5,
  },
];
---

<BaseLayout
  title="Restaurante Campestre — Laguna Escondida | Marinilla, Antioquia"
  description="Restaurante campestre con vista al lago en Marinilla. Come Yamu, Tilapia, Cachama y Trucha frescos del lago, en una construcción en guadua a 45 minutos de Medellín."
>
  <Navbar />

  <!-- ── 1. HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[85vh] flex items-end" id="inicio" data-section="restaurante-hero">
    <!-- Imagen de fondo -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/restaurante/hero-restaurante.jpg"
        alt="Restaurante campestre Laguna Escondida con vista al lago en Marinilla, Antioquia"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-linear-to-t from-lake-700/85 via-lake-700/45 via-40% to-transparent to-70%"></div>
    </div>

    <!-- Breadcrumb -->
    <div class="absolute top-6 left-0 right-0 z-10 px-4">
      <div class="max-w-6xl mx-auto">
        <nav class="text-white/60 text-sm font-body flex items-center gap-2">
          <a href="/" class="hover:text-white transition-colors">Inicio</a>
          <span>/</span>
          <a href="/#experiencias" class="hover:text-white transition-colors">Experiencias</a>
          <span>/</span>
          <span class="text-white/90">Restaurante</span>
        </nav>
      </div>
    </div>

    <!-- Contenido -->
    <div class="relative z-10 px-4 max-w-4xl xl:max-w-5xl mx-auto pb-12 sm:pb-20 w-full">
      <div class="flex flex-col items-start gap-5">
        <h1 class="font-display text-3xl sm:text-4xl md:text-6xl xl:text-7xl text-white leading-tight text-shadow-hero hero-animate">
          Come frente al lago.<br />
          <span class="text-earth-300">Pescado del día.</span>
        </h1>

        <p class="hidden sm:block text-lg sm:text-xl md:text-2xl text-white/90 font-body max-w-2xl text-shadow-hero hero-animate hero-animate-delay-1">
          Restaurante campestre en guadua con vista al agua. Yamu, Tilapia, Cachama y Trucha frescos del lago — a 45 minutos de Medellín.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-2 hero-animate hero-animate-delay-2">
          <a
            href={waHref}
            class="btn btn-lg bg-white text-lake-700 hover:bg-lake-50 border-0 font-body font-semibold text-lg px-8"
            data-event="whatsapp_click" data-location="restaurante-hero"
          >
            <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Reservar mesa
          </a>
          <a
            href="#platos"
            class="btn btn-lg btn-outline border-white text-white hover:bg-white/20 hover:border-white font-body font-semibold text-lg px-8"
          >
            Ver platos estrella
          </a>
        </div>

        <div class="flex items-center gap-2 mt-2 text-white/80 text-shadow-hero hero-animate hero-animate-delay-3">
          <StarRating />
          <span class="font-body text-sm">4.6 en Google Maps · Marinilla, Antioquia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 2. CONCEPTO ─────────────────────────────────────────── -->
  <section class="section-padding bg-lake-gradient" data-section="restaurante-concepto">
    <div class="section-container">
      <h2 class="section-heading reveal text-lake-700">
        ¿Qué hace diferente a nuestro restaurante?
      </h2>
      <p class="section-subtitle reveal stagger-1">
        No es solo comer. Es sentarse frente al lago, con el sonido del agua y el olor a madera de guadua.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10 reveal stagger-2">
        <!-- Pilar 1 -->
        <div class="flex flex-col items-center text-center gap-4 p-6">
          <div class="w-16 h-16 bg-lake-100 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-lake-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M6.5 12c3-6 10-6 14-2-4 4-11 4-14-2z M6.5 12c3 6 10 6 14 2 M3 12h3.5"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-lake-700">Pescado del día</h3>
          <p class="font-body text-neutral/80 text-sm leading-relaxed">
            Cada plato sale directo del lago al plato. Sin congelados, sin intermediarios. El mismo pescado que ves en el agua en la mañana, en tu mesa al mediodía.
          </p>
        </div>

        <!-- Pilar 2 -->
        <div class="flex flex-col items-center text-center gap-4 p-6">
          <div class="w-16 h-16 bg-earth-100 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-earth-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-lake-700">Ambiente en guadua</h3>
          <p class="font-body text-neutral/80 text-sm leading-relaxed">
            Construcción tradicional en guadua, sobre la orilla del lago. Cada mesa tiene vista al agua. El silencio de la vereda reemplaza el ruido de la ciudad.
          </p>
        </div>

        <!-- Pilar 3 -->
        <div class="flex flex-col items-center text-center gap-4 p-6">
          <div class="w-16 h-16 bg-lake-100 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-lake-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2 M9 11a4 4 0 100-8 4 4 0 000 8z M23 21v-2a4 4 0 00-3-3.87 M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-lake-700">Para toda la familia</h3>
          <p class="font-body text-neutral/80 text-sm leading-relaxed">
            Los adultos comen y descansan frente al lago. Los niños pescan mientras esperan. Un plan completo sin necesitar moverse de un solo lugar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3. PLATOS ESTRELLA ──────────────────────────────────── -->
  <section class="section-padding bg-sand-gradient" id="platos" data-section="restaurante-platos">
    <div class="section-container">
      <h2 class="section-heading reveal">Platos estrella</h2>
      <p class="section-subtitle reveal stagger-1">
        Pescados frescos del lago, preparados con recetas de la casa. Menú campestre, auténtico y sin complicaciones.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal stagger-2">
        {platos.map((plato) => (
          <div class="card-hoverable overflow-hidden group">
            <!-- Imagen del plato -->
            <div class="relative h-48 bg-lake-50 overflow-hidden">
              <img
                src={plato.img}
                alt={plato.imgAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <span class={`absolute top-3 left-3 text-xs font-body font-semibold px-2.5 py-1 rounded-full ${plato.badgeClass}`}>
                {plato.badge}
              </span>
            </div>
            <!-- Texto -->
            <div class="p-5">
              <h3 class="font-display text-lg text-lake-700 mb-2">{plato.nombre}</h3>
              <p class="font-body text-sm text-neutral/75 leading-relaxed">{plato.descripcion}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Link al menú completo -->
      <div class="text-center mt-10 reveal stagger-3">
        <p class="font-body text-neutral/60 text-sm mb-3">¿Quieres ver todos los platos y acompañamientos?</p>
        <a href="/menu/" class="section-cta">
          Ver menú completo →
        </a>
      </div>
    </div>
  </section>

  <!-- ── 4. FEATURE: PESCA TU ALMUERZO ─────────────────────── -->
  <section class="section-padding bg-white" data-section="restaurante-pesca-almuerzo">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Imagen -->
        <div class="reveal order-2 lg:order-1">
          <div class="relative rounded-brand overflow-hidden shadow-brand-lg aspect-4/3">
            <img
              src="/images/restaurante/pesca-almuerzo.jpg"
              alt="Persona pescando en el lago de Laguna Escondida antes de almorzar"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Texto -->
        <div class="reveal stagger-1 order-1 lg:order-2 flex flex-col gap-6">
          <span class="font-body text-earth-500 font-semibold text-sm uppercase tracking-widest">
            Del lago al plato
          </span>
          <h2 class="font-display text-3xl sm:text-4xl text-lake-700 leading-tight">
            Pesca tu almuerzo.
          </h2>
          <p class="font-body text-neutral/80 text-lg leading-relaxed">
            En Laguna Escondida puedes pescar tu propio Yamu o Tilapia en la mañana y pedirle a nuestra cocina que lo prepare al mediodía. Es una de esas experiencias que pocas personas han vivido — y que no se olvida.
          </p>
          <p class="font-body text-neutral/80 leading-relaxed">
            No necesitas experiencia previa. Nuestro equipo te ayuda con el equipo y las técnicas. Cualquier persona de cualquier edad puede hacerlo.
          </p>
          <a
            href="/experiencias/pesca-deportiva/"
            class="inline-flex items-center gap-2 text-lake-500 font-semibold font-body hover:text-lake-700 transition-colors group w-fit"
          >
            Conocer la pesca deportiva
            <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. FEATURE: VISTA AL LAGO ──────────────────────────── -->
  <section class="section-padding bg-sand-gradient" data-section="restaurante-espacio">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Texto -->
        <div class="reveal flex flex-col gap-6">
          <span class="font-body text-earth-500 font-semibold text-sm uppercase tracking-widest">
            El espacio
          </span>
          <h2 class="font-display text-3xl sm:text-4xl text-lake-700 leading-tight">
            Una cocina con vista al lago.
          </h2>
          <p class="font-body text-neutral/80 text-lg leading-relaxed">
            Nuestro restaurante está construido en guadua, sobre la orilla misma del lago. Cada mesa tiene vista al agua. No hay pantallas, no hay ruido — solo el lago, la naturaleza y una buena comida.
          </p>
          <p class="font-body text-neutral/80 leading-relaxed">
            Es el mismo espacio que los lugareños de Marinilla conocen hace años. Auténtico, sin pretensiones, y con el sabor de la cocina campestre antioqueña.
          </p>

          <!-- Mini info -->
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-lake-100 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-lake-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <p class="font-body font-semibold text-lake-700 text-sm">Sáb, Dom y Festivos</p>
                <p class="font-body text-neutral/70 text-sm">9:00 AM – 6:00 PM</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-lake-100 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-lake-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2 M9 7a4 4 0 100 0 M23 21v-2a4 4 0 00-3-3.87 M16 3.13a4 4 0 010 7.75"/>
                </svg>
              </div>
              <div>
                <p class="font-body font-semibold text-lake-700 text-sm">Entre semana</p>
                <p class="font-body text-neutral/70 text-sm">Con reserva previa</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Imagen -->
        <div class="reveal stagger-1">
          <div class="relative rounded-brand overflow-hidden shadow-brand-lg aspect-4/3">
            <img
              src="/images/restaurante/cocina-vista-lago.jpg"
              alt="Interior del restaurante en guadua de Laguna Escondida con vista al lago"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 6. INFORMACIÓN PRÁCTICA ────────────────────────────── -->
  <section class="section-padding bg-lake-700" id="info" data-section="restaurante-info">
    <div class="section-container">
      <h2 class="section-heading reveal text-white">
        ¿Cómo reservar tu mesa?
      </h2>
      <p class="section-subtitle reveal stagger-1 text-white/70">
        Los fines de semana no necesitas reserva. Entre semana, avísanos con anticipación por WhatsApp.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10 reveal stagger-2">
        <!-- Horarios -->
        <div class="bg-white/10 border border-white/15 rounded-brand p-6 flex flex-col gap-4">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-earth-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-white">Horarios</h3>
          <ul class="font-body text-white/75 text-sm space-y-2">
            <li class="flex justify-between">
              <span>Sábados y domingos</span>
              <span class="text-earth-300 font-semibold">9am – 6pm</span>
            </li>
            <li class="flex justify-between">
              <span>Festivos</span>
              <span class="text-earth-300 font-semibold">9am – 6pm</span>
            </li>
            <li class="flex justify-between">
              <span>Entre semana</span>
              <span class="text-white/50">Con reserva</span>
            </li>
          </ul>
        </div>

        <!-- Cómo reservar -->
        <div class="bg-white/10 border border-white/15 rounded-brand p-6 flex flex-col gap-4">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-earth-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-white">Cómo reservar</h3>
          <ul class="font-body text-white/75 text-sm space-y-2">
            <li>Por WhatsApp al <span class="text-earth-300 font-semibold">+57 319 431 3781</span></li>
            <li>Fines de semana y festivos: <span class="text-white/90">sin reserva, solo llegar</span></li>
            <li>Entre semana: <span class="text-white/90">reserva obligatoria</span></li>
          </ul>
          <a
            href={waHref}
            class="mt-2 btn btn-sm bg-earth-300 hover:bg-earth-500 text-lake-700 border-0 font-body font-semibold w-full"
            data-event="whatsapp_click" data-location="restaurante-info"
          >
            Escribir por WhatsApp
          </a>
        </div>

        <!-- Cómo llegar -->
        <div class="bg-white/10 border border-white/15 rounded-brand p-6 flex flex-col gap-4">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-earth-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-white">Cómo llegar</h3>
          <ul class="font-body text-white/75 text-sm space-y-2">
            <li>Desde Medellín: <span class="text-earth-300 font-semibold">45 min</span> por la autopista Medellín–Bogotá</li>
            <li>Desde Rionegro: <span class="text-earth-300 font-semibold">15 min</span> directo</li>
            <li>Vereda La Primavera, Marinilla, Antioquia</li>
          </ul>
          <a
            href="https://maps.app.goo.gl/5EN4yjbr42zDCiyy6"
            target="_blank"
            rel="noopener"
            class="mt-2 btn btn-sm btn-outline border-white/30 text-white hover:bg-white/10 hover:border-white font-body font-semibold w-full"
            data-event="maps_click" data-location="restaurante-info"
          >
            Abrir en Google Maps
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 7. RESEÑAS ─────────────────────────────────────────── -->
  <section class="section-padding bg-sand-gradient" data-section="restaurante-resenas">
    <div class="section-container">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10">
        <div>
          <h2 class="section-heading text-left mb-2 reveal">
            Lo que dicen quienes comieron aquí
          </h2>
          <div class="flex items-center gap-2 reveal stagger-1">
            <StarRating size="sm" />
            <span class="font-body text-neutral/70 text-sm">4.6 en Google Maps</span>
          </div>
        </div>
        <a
          href="https://maps.app.goo.gl/5EN4yjbr42zDCiyy6"
          target="_blank"
          rel="noopener"
          class="section-cta shrink-0 reveal stagger-1"
          data-event="maps_click" data-location="restaurante-resenas"
        >
          Ver en Google Maps
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal stagger-2">
        {resenas.map((resena) => (
          <div class="card-hoverable flex flex-col gap-4 p-6">
            <StarRating count={resena.estrellas} size="sm" />
            <p class="font-body text-neutral/80 leading-relaxed flex-1">
              "{resena.texto}"
            </p>
            <p class="font-body text-sm font-semibold text-lake-700">{resena.autor}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 8. CTA FINAL ───────────────────────────────────────── -->
  <section class="section-padding bg-lake-700" data-section="restaurante-cta-final">
    <div class="section-container text-center">
      <h2 class="font-display text-3xl sm:text-4xl xl:text-5xl text-white mb-4 reveal">
        ¿Listo para comer frente al lago?
      </h2>
      <p class="font-body text-white/70 text-lg max-w-xl mx-auto mb-8 reveal stagger-1">
        Los fines de semana no necesitas reserva — solo llegar. Entre semana, escríbenos y te apartamos una mesa.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal stagger-2">
        <a
          href={waHref}
          class="btn btn-lg bg-[#25D366] hover:bg-[#1ea855] text-white border-0 font-body font-semibold text-lg px-8"
          data-event="whatsapp_click" data-location="restaurante-cta-final"
        >
          <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Reservar por WhatsApp
        </a>
        <a
          href="/#experiencias"
          class="btn btn-lg btn-outline border-white/50 text-white hover:bg-white/10 hover:border-white font-body font-semibold text-lg px-8"
        >
          Ver otras experiencias
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <!-- WhatsApp flotante -->
  <a
    id="wa-floating-btn"
    href={waHref}
    class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] hover:bg-[#1ea855] rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-all duration-200"
