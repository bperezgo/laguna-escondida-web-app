---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import StarRating from '../../../components/StarRating.astro';
import Eyebrow from '../../../components/ui/Eyebrow.astro';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import Button from '../../../components/ui/Button.astro';
import LinkRule from '../../../components/ui/LinkRule.astro';
import ArchImage from '../../../components/ui/ArchImage.astro';

const waNumber = '573194313781';
const waMessage = 'Hola, quiero reservar una mesa en el restaurante de Laguna Escondida';
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

const pilares = [
  {
    numero: '01',
    titulo: 'Pescado del día',
    descripcion: 'Cada plato sale directo del lago al plato. Sin congelados, sin intermediarios. El mismo pescado que ves en el agua en la mañana, en tu mesa al mediodía.',
  },
  {
    numero: '02',
    titulo: 'Ambiente en guadua',
    descripcion: 'Construcción tradicional en guadua, sobre la orilla del lago. Cada mesa tiene vista al agua. El silencio de la vereda reemplaza el ruido de la ciudad.',
  },
  {
    numero: '03',
    titulo: 'Para toda la familia',
    descripcion: 'Los adultos comen y descansan frente al lago. Los niños pescan mientras esperan. Un plan completo sin necesitar moverse de un solo lugar.',
  },
];

const platos = [
  {
    nombre: 'Yamu Frito Entero',
    descripcion: 'La estrella del lago. Servido entero, crujiente por fuera y jugoso por dentro. Con patacones y ensalada fresca.',
    badge: 'Plato estrella',
    img: '/images/restaurante/yamu-frito.jpg',
    imgAlt: 'Yamu frito entero con patacones en Laguna Escondida',
  },
  {
    nombre: 'Tilapia a la Plancha',
    descripcion: 'Fresca del lago, preparada a la plancha con limón y hierbas de la región. Liviana y llena de sabor.',
    badge: 'Muy pedido',
    img: '/images/restaurante/tilapia-plancha.jpg',
    imgAlt: 'Tilapia a la plancha en restaurante campestre Laguna Escondida',
  },
  {
    nombre: 'Cachama al Ajillo',
    descripcion: 'Receta de la casa. Cachama entera en salsa de ajo y mantequilla, acompañada de yuca frita y arroz.',
    badge: 'Receta de la casa',
    img: '/images/restaurante/cachama-ajillo.jpg',
    imgAlt: 'Cachama al ajillo con yuca frita en Laguna Escondida',
  },
  {
    nombre: 'Trucha con Hierbas',
    descripcion: 'El clásico campestre. Trucha entera marinada en hierbas frescas, al horno con papas criollas.',
    badge: 'Del río al campo',
    img: '/images/restaurante/trucha-hierbas.jpg',
    imgAlt: 'Trucha con hierbas al horno en restaurante Laguna Escondida',
  },
];

const resenas = [
  {
    texto: 'El Yamu frito fue lo mejor que he comido en mucho tiempo. Nunca había probado nada así. El lugar es hermoso y la atención, excelente.',
    autor: 'Visitante de Google Maps',
    detalle: 'Reseña verificada · Google',
    estrellas: 5,
  },
  {
    texto: 'Pescamos en la mañana y al mediodía nos prepararon el mismo pescado que habíamos sacado del lago. Una experiencia que no se olvida.',
    autor: 'Visitante de Google Maps',
    detalle: 'Reseña verificada · Google',
    estrellas: 5,
  },
  {
    texto: 'La vista al lago mientras comes no tiene precio. Los patacones caseros y la Cachama al ajillo, una combinación perfecta.',
    autor: 'Visitante de Google Maps',
    detalle: 'Reseña verificada · Google',
    estrellas: 5,
  },
];

const initials = (author: string) =>
  author.replace(/[^\p{L}\s]/gu, '')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0])
    .join('')
    .toUpperCase();
---

<BaseLayout
  title="Restaurante Campestre — Laguna Escondida | Marinilla, Antioquia"
  description="Restaurante campestre con vista al lago en Marinilla. Come Yamu, Tilapia, Cachama y Dorada frescos del lago, en una construcción en guadua a 1 hora de Medellín."
>
  <Navbar />

  <!-- ① HERO -->
  <section class="resto-hero" id="inicio" data-section="restaurante-hero" data-screen-label="Restaurante hero">
    <div class="hero-bg">
      <img
        src="/images/restaurante/hero-restaurante.jpg"
        alt="Restaurante campestre Laguna Escondida con vista al lago en Marinilla, Antioquia"
        loading="eager"
        fetchpriority="high"
        data-parallax
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/#experiencias">Experiencias</a>
        <span aria-hidden="true">/</span>
        <span class="is-current">Restaurante</span>
      </nav>

      <div class="hero-content">
        <Eyebrow text="Restaurante campestre · Vista al lago" inverse />
        <h1 class="hero-title reveal">
          Come frente al lago.<br />
          <em>Pescado del día.</em>
        </h1>
        <p class="hero-lead reveal stagger-1">
          Restaurante campestre en guadua con vista al agua. Yamú, Tilapia, Cachama
          y Dorada frescos del lago — a 1 hora de Medellín.
        </p>

        <div class="hero-trust reveal stagger-2">
          <StarRating />
          <span>4.6 en Google Maps · Marinilla, Antioquia</span>
        </div>

        <div class="hero-actions reveal stagger-3">
          <Button
            variant="inverse-primary"
            href={waHref}
            event="whatsapp_click"
            location="restaurante-hero"
            target="_blank"
            rel="noopener"
            withDot
          >
            Reservar mesa
          </Button>
          <Button
            variant="inverse-secondary"
            href="#platos"
          >
            Ver platos estrella
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ② CONCEPTO -->
  <section class="concepto-section" data-section="restaurante-concepto" data-screen-label="Concepto">
    <div class="section-container">
      <SectionHeading
        eyebrow="El concepto"
        title="¿Por qué la gente viene desde Medellín solo a comer aquí?"
        subtitle="No es solo comer. Es sentarse frente al lago, con el sonido del agua y el olor a madera de guadua."
        class="reveal"
      />

      <div class="pilares-grid reveal stagger-1">
        {pilares.map((p) => (
          <article class="pilar-card">
            <div class="pilar-index">{p.numero}</div>
            <h3 class="pilar-title">{p.titulo}</h3>
            <p class="pilar-body">{p.descripcion}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ③ PLATOS ESTRELLA -->
  <section class="platos-section" id="platos" data-section="restaurante-platos" data-screen-label="Platos estrella">
    <div class="section-container">
      <SectionHeading
        eyebrow="La carta"
        title="Platos estrella"
        subtitle="Del lago a la mesa: Yamú, Tilapia y Cachama frescos, preparados con recetas de la casa. Menú campestre, auténtico y sin complicaciones."
        class="reveal"
      />

      <div class="platos-grid reveal stagger-1">
        {platos.map((plato, i) => (
          <article class="plato-card">
            <div class="plato-media">
              <img src={plato.img} alt={plato.imgAlt} loading="lazy" />
              <span class="plato-badge">{plato.badge}</span>
            </div>
            <div class="plato-body">
              <p class="plato-index">{String(i + 1).padStart(2, '0')}</p>
              <h3 class="plato-name">{plato.nombre}</h3>
              <p class="plato-desc">{plato.descripcion}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="platos-cta reveal stagger-2">
        <LinkRule
          href="/menu/"
          label="Ver menú completo"
          event="menu_click"
          location="restaurante-platos"
        />
      </div>
    </div>
  </section>

  <!-- ④ PESCA TU ALMUERZO -->
  <section class="feature-section" data-section="restaurante-pesca-almuerzo" data-screen-label="Pesca tu almuerzo">
    <div class="section-container">
      <div class="feature-grid">
        <div class="feature-media reveal">
          <ArchImage
            src="/images/restaurante/pesca-almuerzo.jpg"
            alt="Persona pescando en el lago de Laguna Escondida antes de almorzar"
            variant="arch-soft"
            ratio="4x5"
          />
          <figcaption class="media-caption">
            <span class="idx">01</span>
            <span>Del lago al plato · Vereda La Primavera</span>
          </figcaption>
        </div>

        <div class="feature-text reveal stagger-1">
          <Eyebrow text="Del lago al plato" />
          <h2 class="feature-title">
            Pesca tu almuerzo,<br />
            <em>comételo al mediodía.</em>
          </h2>
          <p class="feature-lead">
            En Laguna Escondida puedes pescar tu propio Yamu o Tilapia en la
            mañana y pedirle a nuestra cocina que lo prepare al mediodía. Una de
            esas experiencias que pocas personas han vivido — y que no se olvida.
          </p>
          <p class="feature-body">
            No necesitas experiencia previa. Nuestro equipo te ayuda con el
            equipo y las técnicas. Cualquier persona de cualquier edad puede hacerlo.
          </p>
          <LinkRule
            href="/experiencias/pesca-deportiva/"
            label="Conocer la pesca deportiva"
            event="pesca_click"
            location="restaurante-feature"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ⑤ ESPACIO -->
  <section class="espacio-section" data-section="restaurante-espacio" data-screen-label="El espacio">
    <div class="section-container">
      <div class="espacio-grid">
        <div class="espacio-text reveal">
          <Eyebrow text="El espacio" />
          <h2 class="espacio-title">
            Una cocina con vista<br />
            <em>al lago.</em>
          </h2>
          <p class="espacio-lead">
            Nuestro restaurante está construido en guadua, sobre la orilla misma
            del lago. Cada mesa tiene vista al agua. No hay pantallas, no hay
            ruido — solo el lago, la naturaleza y una buena comida.
          </p>
          <p class="espacio-body">
            El mismo espacio donde Marinilla lleva años reuniéndose — ahora renovado
            como Laguna Escondida. Auténtico, sin pretensiones, y con el sabor de
            la cocina campestre antioqueña.
          </p>

          <dl class="espacio-hours">
            <div>
              <dt>Todos los días</dt>
              <dd>10:00 AM – 10:00 PM</dd>
            </div>
          </dl>
        </div>

        <div class="espacio-media reveal stagger-1">
          <ArchImage
            src="/images/restaurante/cocina-vista-lago.jpg"
            alt="Interior del restaurante en guadua de Laguna Escondida con vista al lago"
            variant="arch-soft"
            ratio="3x4"
          />
          <figcaption class="media-caption">
            <span class="idx">02</span>
            <span>Ramada en guadua · Orilla del lago</span>
          </figcaption>
        </div>
      </div>
    </div>
  </section>

  <!-- ⑥ INFO PRÁCTICA -->
  <section class="info-section" id="info" data-section="restaurante-info" data-screen-label="Info práctica">
    <div class="section-container">
      <SectionHeading
        eyebrow="Reservas"
        title="¿Cómo reservar tu mesa?"
        subtitle="Los fines de semana no necesitas reserva. Entre semana, avísanos con anticipación por WhatsApp."
        inverse
        class="reveal"
      />

      <div class="info-grid reveal stagger-1">
        <article class="info-card">
          <p class="info-index">01</p>
          <h3 class="info-title">Horarios</h3>
          <ul class="info-list">
            <li><span>Todos los días</span><span class="accent">10:00 AM – 10:00 PM</span></li>
          </ul>
        </article>

        <article class="info-card">
          <p class="info-index">02</p>
          <h3 class="info-title">Cómo reservar</h3>
          <ul class="info-list">
            <li>Por WhatsApp al <span class="accent">+57 319 431 3781</span></li>
            <li>Fines de semana y festivos: sin reserva, solo llegar</li>
            <li>Entre semana: reserva obligatoria</li>
          </ul>
          <div class="info-cta">
            <Button
              variant="inverse-primary"
              href={waHref}
              event="whatsapp_click"
              location="restaurante-info"
              target="_blank"
              rel="noopener"
            >
              Escribir por WhatsApp
            </Button>
          </div>
        </article>

        <article class="info-card">
          <p class="info-index">03</p>
          <h3 class="info-title">Cómo llegar</h3>
          <ul class="info-list">
            <li>Desde Medellín: <span class="accent">1 hora</span> por la autopista Medellín–Bogotá</li>
            <li>Desde Rionegro: <span class="accent">15 min</span> directo</li>
            <li>Vereda La Primavera, Marinilla, Antioquia</li>
          </ul>
          <div class="info-cta">
            <Button
              variant="inverse-secondary"
              href="https://maps.app.goo.gl/5EN4yjbr42zDCiyy6"
              event="maps_click"
              location="restaurante-info"
              target="_blank"
              rel="noopener"
            >
              Abrir en Google Maps
            </Button>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ⑦ RESEÑAS -->
  <section class="resenas-section" data-section="restaurante-resenas" data-screen-label="Reseñas">
    <div class="section-container">
      <SectionHeading
        eyebrow="Lo que dicen"
        title="Quienes comieron aquí"
        subtitle="4.6 en Google Maps. Reseñas verificadas de visitantes reales."
        centered
        class="reveal"
      />

      <div class="resenas-grid reveal stagger-1">
        {resenas.map((r) => (
          <article class="resena-card">
            <div class="stars" aria-label={`${r.estrellas} / 5`}>
              {Array.from({ length: r.estrellas }).map(() => (
                <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 1.5l1.9 4.1 4.5.5-3.3 3 .9 4.4L8 11.2l-4 2.3.9-4.4-3.3-3 4.5-.5z" />
                </svg>
              ))}
            </div>
            <blockquote>{r.texto}</blockquote>
            <footer class="who">
              <div class="avatar" aria-hidden="true">{initials(r.autor)}</div>
              <div>
                <p class="name">{r.autor}</p>
                <p class="detail">{r.detalle}</p>
              </div>
            </footer>
          </article>
        ))}
      </div>

      <div class="resenas-cta reveal stagger-2">
        <LinkRule
          href="https://maps.app.goo.gl/5EN4yjbr42zDCiyy6"
          label="Ver en Google Maps"
          event="maps_click"
          location="restaurante-resenas"
        />
      </div>
    </div>
  </section>

  <!-- ⑧ CTA FINAL -->
  <section class="resto-cta" data-section="restaurante-cta-final" data-screen-label="CTA restaurante">
    <div class="cta-container">
      <div class="cta-text reveal">
        <Eyebrow text="Reserva tu mesa" inverse />
        <h2 class="cta-heading">
          ¿Listo para comer<br />
          <em>frente al lago?</em>
        </h2>
        <p class="cta-lead">
          Los fines de semana no necesitas reserva — solo llegar. Entre semana,
          escríbenos y te apartamos una mesa.
        </p>
      </div>

      <div class="cta-actions reveal stagger-1">
        <Button
          variant="inverse-primary"
          href={waHref}
          event="whatsapp_click"
          location="restaurante-cta-final"
          target="_blank"
          rel="noopener"
          withDot
        >
          Reservar por WhatsApp
        </Button>
        <Button
          variant="inverse-secondary"
          href="/#experiencias"
        >
          Ver otras experiencias
        </Button>
      </div>
    </div>
  </section>

  <Footer />

  <a
    id="wa-floating-btn"
    href={waHref}
    class="wa-floating"
    aria-label="Contactar por WhatsApp"
    data-event="whatsapp_click"
    data-location="restaurante-floating"
    target="_blank"
    rel="noopener"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</BaseLayout>

<script>
  const parallaxImg = document.querySelector<HTMLImageElement>('.resto-hero [data-parallax]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (parallaxImg && !reduceMotion) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY * -0.15;
      parallaxImg.style.transform = `translate3d(0, ${y}px, 0)`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  }
</script>

<style>
  /* ── HERO ───────────────────────────── */
  .resto-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    background: var(--color-lake-800);
    color: var(--color-sand-50);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-bg img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(12, 36, 52, 0.85) 0%,
      rgba(12, 36, 52, 0.45) 40%,
      rgba(12, 36, 52, 0.1) 70%,
      transparent 100%
    );
  }

  .hero-container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: 48px 80px;
  }

  .breadcrumb {
    position: absolute;
    top: 32px;
    left: var(--gutter);
    right: var(--gutter);
    display: flex;
    gap: 10px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.55);
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-3, 200ms) var(--ease-out);
  }

  .breadcrumb a:hover {
    color: var(--color-sand-50);
  }

  .breadcrumb .is-current {
    color: var(--color-earth-300);
  }

  .hero-content {
    max-width: 720px;
    display: grid;
    gap: 20px;
  }

  .hero-title {
    margin: 16px 0 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--color-sand-50);
  }

  .hero-title em {
    font-style: italic;
    color: var(--color-earth-300);
    font-weight: 300;
  }

  .hero-lead {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.82);
    max-width: 52ch;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.6);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 8px;
  }

  /* ── CONCEPTO ─────────────────────── */
  .concepto-section {
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
  }

  .section-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .pilares-grid {
    margin-top: 64px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 720px) {
    .pilares-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
  }

  .pilar-card {
    padding-top: 24px;
    border-top: 1px solid var(--color-line-gold, var(--color-earth-300));
  }

  .pilar-index {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-ink, var(--color-earth-400));
  }

  .pilar-title {
    margin: 12px 0 10px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    line-height: 1.2;
    color: var(--color-ink);
  }

  .pilar-body {
    margin: 0;
