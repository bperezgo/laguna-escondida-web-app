---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Reviews from '../../../components/Reviews.astro';
import StarRating from '../../../components/StarRating.astro';
import PescaFAQ from '../../../components/PescaFAQ.astro';
import { sanityClient, urlFor, responsiveImage } from '../../../lib/sanity';
import { FISH_SPECIES_QUERY } from '../../../lib/queries/fishSpecies';
import { HERO_SECTION_QUERY } from '../../../lib/queries/heroSection';

const speciesData = await sanityClient.fetch(FISH_SPECIES_QUERY);
const hero = await sanityClient.fetch(HERO_SECTION_QUERY);

const heroImg = hero?.backgroundImage
  ? responsiveImage(hero.backgroundImage, [640, 1024, 1600, 1920], '100vw')
  : { src: '/images/hero/lago-comedor-vista.jpg', srcset: '', sizes: '' };

const WA_NUMBER = '573194313781';
const WA_MESSAGE = 'Hola, quiero reservar una visita de pesca deportiva en Laguna Escondida';
const waHref = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MESSAGE)}`;

// Datos enriquecidos por especie (hardcoded por ahora, puede migrar a Sanity)
const speciesExtra: Record<string, { flavor: string; technique: string; avgWeight: string }> = {
  'Yamu': {
    flavor: 'Carne firme e intensa. El favorito para preparar en ceviche o frito con patacones.',
    technique: 'Carnada viva o señuelo. Puede tardar 1–2 horas antes de picar — el reto que vale la pena.',
    avgWeight: '2–5 kg',
  },
  'Dorada': {
    flavor: 'Carne blanca, suave y delicada. Perfecta frita entera o al ajillo con limón.',
    technique: 'Lombriz o masa. Suele picar en los primeros 15–30 minutos.',
    avgWeight: '300–800 g',
  },
  'Cachama': {
    flavor: 'Carne jugosa con sabor profundo. Excelente asada, frita o en sancocho campestre.',
    technique: 'Frutas (mango, guayaba) o maíz partido. Más activa al mediodía.',
    avgWeight: '1–3 kg',
  },
  'Tilapia Roja': {
    flavor: 'Carne blanca y suave, absorbe muy bien salsas y aliños. La preferida de los niños.',
    technique: 'Masa o lombriz. La más activa del lago — ideal para principiantes.',
    avgWeight: '300–700 g',
  },
  'Tilapia Nilotica': {
    flavor: 'Textura firme, sabor limpio. Muy apreciada frita entera con arroz y patacón.',
    technique: 'Masa o pan. Pica con frecuencia, buena opción cuando hay poca actividad.',
    avgWeight: '400–900 g',
  },
};

const difficultyLabel: Record<string, string> = {
  Facil: 'Fácil',
  Media: 'Media',
  Dificil: 'Difícil',
};
const difficultyBadge: Record<string, string> = {
  Facil: 'badge-primary',
  Media: 'badge-secondary',
  Dificil: 'badge-accent',
};

const PAGE_TITLE = 'Pesca Deportiva en Marinilla — 5 especies | Laguna Escondida';
const PAGE_DESCRIPTION = 'Pesca Yamu, Dorada, Cachama, Tilapia Roja y Nilotica en un lago privado. La mayor variedad del Oriente Antioqueño, a 45 min de Medellín. Para todos los niveles.';
---

<BaseLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION}>
  <Navbar />
  <main>

    <!-- ① HERO -->
    <section class="hero min-h-[80vh] relative" id="inicio" data-section="pesca-hero">
      <div class="absolute inset-0 overflow-hidden">
        <img
          src={heroImg.src}
          srcset={heroImg.srcset}
          sizes={heroImg.sizes}
          alt="Lago de pesca deportiva en Laguna Escondida, Marinilla, Antioquia"
          class="w-full h-full object-cover will-change-transform"
          loading="eager"
          fetchpriority="high"
          data-parallax
        />
        <div class="absolute inset-0 bg-linear-to-t from-lake-700/85 via-lake-700/45 via-40% to-transparent to-70%"></div>
      </div>

      <div class="hero-content relative z-10 px-4 max-w-4xl xl:max-w-5xl mx-auto flex items-end min-h-[80vh] pb-10 sm:pb-16">
        <div class="flex flex-col items-start gap-5 text-left">
          <h1 class="font-display text-3xl sm:text-4xl md:text-6xl xl:text-7xl text-white leading-tight text-shadow-hero hero-animate">
            Pesca 5 especies.<br/>
            Ninguna truchera<br/>
            <span class="text-earth-300">las tiene todas.</span>
          </h1>

          <p class="hidden sm:block text-lg sm:text-xl md:text-2xl text-white/90 font-body max-w-2xl text-shadow-hero hero-animate hero-animate-delay-1">
            Yamu, Dorada, Cachama, Tilapia Roja y Nilotica en un lago privado en Marinilla.
            No se necesita experiencia previa — traes ganas, nosotros ponemos el resto.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mt-4 hero-animate hero-animate-delay-2">
            <a
              href={waHref}
              class="btn btn-lg bg-white text-lake-700 hover:bg-lake-50 border-0 font-body font-semibold text-lg px-8"
              data-event="whatsapp_click" data-location="pesca-hero"
            >
              <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Reservar por WhatsApp
            </a>
            <a
              href="#como-funciona"
              class="btn btn-lg btn-outline border-white text-white hover:bg-white/20 hover:border-white font-body font-semibold text-lg px-8"
            >
              Ver cómo funciona ↓
            </a>
          </div>

          <div class="flex items-center gap-2 mt-2 text-white/80 text-shadow-hero hero-animate hero-animate-delay-3">
            <StarRating />
            <span class="font-body text-sm sm:text-base">4.6 en Google Maps · Marinilla, Antioquia</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ② DIFERENCIADORES -->
    <section class="section-padding bg-sand-gradient" id="diferenciadores" data-section="pesca-diferenciadores">
      <div class="section-container">
        <h2 class="section-heading reveal">¿Por qué pescar en Laguna Escondida?</h2>
        <p class="section-subtitle reveal stagger-1">
          No somos una truchera más. Somos el lago con más variedad de especies del Oriente Antioqueño,
          en un ambiente campestre donde la pesca y la gastronomía van de la mano.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal stagger-2">
          <!-- Card 1 -->
          <div class="card-standard text-center">
            <figure class="px-6 pt-6 mb-4">
              <div class="w-16 h-16 bg-lake-50 rounded-full flex items-center justify-center mx-auto">
                <svg class="w-8 h-8 text-lake-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M6.5 12c3-6 10-6 14-2-4 4-11 4-14-2z M6.5 12c3 6 10 6 14 2 M3 12h3.5"/>
                </svg>
              </div>
            </figure>
            <div class="card-body items-center text-center pt-0">
              <h3 class="card-title font-display text-xl text-lake-700">5 especies en un solo lago</h3>
              <p class="font-body text-neutral text-sm">Mientras la mayoría de trucheras solo ofrecen una especie, aquí puedes pescar cinco — cada visita es una experiencia diferente.</p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="card-standard text-center">
            <figure class="px-6 pt-6 mb-4">
              <div class="w-16 h-16 bg-lake-50 rounded-full flex items-center justify-center mx-auto">
                <svg class="w-8 h-8 text-lake-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2 M9 11a4 4 0 100-8 4 4 0 000 8z M23 21v-2a4 4 0 00-3-3.87 M16 3.13a4 4 0 010 7.75"/>
                </svg>
              </div>
            </figure>
            <div class="card-body items-center text-center pt-0">
              <h3 class="card-title font-display text-xl text-lake-700">Para todos los niveles</h3>
              <p class="font-body text-neutral text-sm">Niños desde 4 años, principiantes y pescadores con experiencia. Caña, carnada y orientación incluidas — solo traes las ganas.</p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="card-standard text-center">
            <figure class="px-6 pt-6 mb-4">
              <div class="w-16 h-16 bg-lake-50 rounded-full flex items-center justify-center mx-auto">
                <svg class="w-8 h-8 text-lake-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2 M7 2v20 M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3v7"/>
                </svg>
              </div>
            </figure>
            <div class="card-body items-center text-center pt-0">
              <h3 class="card-title font-display text-xl text-lake-700">Del agua a tu plato</h3>
              <p class="font-body text-neutral text-sm">Lo que pesques, el restaurante lo prepara fresco. No hay nada más campestre que comer tu propia captura frente al lago.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ LAS 5 ESPECIES -->
    <section class="section-padding bg-lake-gradient" id="especies" data-section="pesca-especies">
      <div class="section-container">
        <h2 class="section-heading reveal">Las 5 especies que puedes pescar</h2>
        <p class="section-subtitle max-w-3xl reveal stagger-1">
          Cada especie tiene su propio carácter: algunas pican rápido, otras son todo un reto.
          Todas terminan en un plato delicioso si así lo quieres.
        </p>

        <div class="flex flex-col gap-6 reveal stagger-2">
          {speciesData.map((species: any, i: number) => {
            const extra = speciesExtra[species.name] ?? {
              flavor: species.description,
              technique: 'Consulta con nuestro equipo al llegar.',
              avgWeight: '—',
            };
            return (
              <div class="bg-white rounded-brand shadow-brand overflow-hidden">
                <div class="flex flex-col sm:flex-row">
                  {species.image && (
                    <div class="sm:w-40 sm:flex-shrink-0">
                      <img
                        src={urlFor(species.image).width(160).height(160).fit('crop').url()}
                        alt={species.image?.alt || species.name}
                        class="w-full h-40 sm:h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="flex-1 p-5 sm:p-6">
                    <div class="flex flex-wrap items-center gap-3 mb-3">
                      <h3 class="font-display text-xl text-lake-700">{species.name}</h3>
                      <span class={`badge ${difficultyBadge[species.difficulty] ?? 'badge-primary'} badge-outline font-body text-xs`}>
                        Dificultad: {difficultyLabel[species.difficulty] ?? species.difficulty}
                      </span>
                      <span class="text-xs font-body text-neutral/60 bg-sand-200 px-2 py-0.5 rounded-full">
                        Peso prom. {extra.avgWeight}
                      </span>
                    </div>

                    <div class="grid sm:grid-cols-2 gap-4">
                      <div>
                        <p class="text-xs font-body font-semibold text-earth-500 uppercase tracking-wide mb-1">Sabor</p>
                        <p class="font-body text-neutral text-sm">{extra.flavor}</p>
                      </div>
                      <div>
                        <p class="text-xs font-body font-semibold text-earth-500 uppercase tracking-wide mb-1">Técnica recomendada</p>
                        <p class="font-body text-neutral text-sm">{extra.technique}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ④ CÓMO FUNCIONA -->
    <section class="section-padding bg-white" id="como-funciona" data-section="pesca-como-funciona">
      <div class="section-container">
        <h2 class="section-heading reveal">¿Cómo es la experiencia?</h2>
        <p class="section-subtitle reveal stagger-1">
          Sin complicaciones. Llegas, pescas y comes. Así de sencillo.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-8 reveal stagger-2">
          {[
            {
              step: '01',
              title: 'Llegada',
              description: 'Parqueas, entras y te recibimos con orientación del lugar. Te explicamos las zonas del lago y las especies disponibles.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
            },
            {
              step: '02',
              title: 'Elige tu puesto',
              description: 'Seleccionas tu zona en el lago. Hay puestos al sol, a la sombra y kioscos privados para grupos con reserva anticipada.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
            },
            {
              step: '03',
              title: 'Pesca',
              description: 'Caña y carnada básica incluidas. Nuestro equipo está disponible para ayudarte a pescar tu primera o décima captura.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 12c3-6 10-6 14-2-4 4-11 4-14-2z M6.5 12c3 6 10 6 14 2 M3 12h3.5 M16 10l1-4 M16 14l1 4"/>`,
            },
            {
              step: '04',
              title: 'A la mesa',
              description: 'El restaurante prepara tu captura fresca o pides del menú. Una vista al lago, comida campestre y el sabor de lo que pescaste.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2 M7 2v20 M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3v7"/>`,
            },
          ].map((item) => (
            <div class="relative text-center">
              <p class="font-display text-7xl sm:text-8xl text-earth-300/20 leading-none select-none mb-2">{item.step}</p>
              <div class="w-12 h-12 bg-lake-50 rounded-full flex items-center justify-center mx-auto -mt-8 mb-4 border-2 border-lake-100">
                <svg class="w-6 h-6 text-lake-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={item.icon} />
                </svg>
              </div>
              <h3 class="font-display text-lg text-lake-700 mb-2">{item.title}</h3>
              <p class="font-body text-neutral text-sm leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤ QUÉ INCLUYE -->
    <section class="section-padding bg-sand-100" id="incluye" data-section="pesca-incluye">
      <div class="section-container">
        <h2 class="section-heading reveal">¿Qué incluye la visita?</h2>
        <p class="section-subtitle reveal stagger-1">
          Todo lo que necesitas para pescar está cubierto desde que llegas.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto reveal stagger-2">
          <!-- Incluido -->
          <div class="bg-white rounded-brand shadow-brand p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-lake-50 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-lake-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 class="font-display text-xl text-lake-700">Incluido</h3>
            </div>
            <ul class="space-y-3 font-body text-neutral">
              {[
                'Acceso al lago de pesca deportiva',
                'Caña de pescar y carnada básica',
                'Orientación inicial para nuevos pescadores',
                'Asistencia del equipo durante la jornada',
                'Parqueadero gratuito',
                'Zonas de descanso y mesas al aire libre',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-earth-300 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Opcionales -->
          <div class="bg-white rounded-brand shadow-brand p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-sand-200 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-neutral/50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                </svg>
              </div>
              <h3 class="font-display text-xl text-lake-700">Adicionales</h3>
            </div>
            <ul class="space-y-3 font-body text-neutral">
              {[
                'Preparación de tu captura en el restaurante',
                'Carnadas especiales para Yamu (mayor reto)',
                'Kiosco privado para grupos (reserva anticipada)',
                'Menú completo del restaurante campestre',
                'Bebidas, jugos naturales y postres',
                'Servicio de foto con tu captura',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-neutral/30 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                  </svg>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="text-center mt-10 reveal stagger-3">
          <p class="font-body text-neutral/70 text-sm mb-4">¿Preguntas sobre precios o disponibilidad?</p>
          <a
            href={waHref}
            class="btn btn-primary text-white font-body font-semibold"
            data-event="whatsapp_click" data-location="pesca-incluye"
          >
            Consultar por WhatsApp →
          </a>
        </div>
      </div>
    </section>

    <!-- ⑥ PARA QUIÉN ES -->
    <section class="section-padding bg-sand-gradient" id="para-quien" data-section="pesca-para-quien">
      <div class="section-container">
        <h2 class="section-heading reveal">¿Para quién es esta experiencia?</h2>
        <p class="section-subtitle reveal stagger-1">
          Laguna Escondida recibe a todo tipo de visitantes. Cada uno encuentra algo especial en el lago.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 reveal stagger-2">
          {[
            {
              emoji: '👨‍👩‍👧‍👦',
              title: 'Familias con niños',
              description: 'Niños desde 4 años pueden pescar sin problema. El ambiente es seguro, tranquilo y lejos del ruido de la ciudad. Una forma diferente de pasar el fin de semana en familia.',
            },
            {
              emoji: '👫',
              title: 'Parejas',
              description: 'Un plan diferente. Naturaleza, tranquilidad y la complicidad de esperar juntos a que pique. Luego un almuerzo frente al lago con lo que pescaron.',
            },
            {
              emoji: '🍻',
              title: 'Grupos de amigos',
              description: 'Competencia sana: quién pesca más, quién pesca el más grande. Con kiosco privado disponible para grupos que quieran su espacio exclusivo.',
            },
            {
              emoji: '🎣',
              title: 'Pescadores con experiencia',
              description: 'El Yamu es el reto. Difícil de pescar, espectacular al comerlo. Si ya dominas la trucha, ven a buscar algo que te haga sudar.',
            },
          ].map((item) => (
            <div class="bg-white rounded-brand shadow-brand p-6 flex gap-4">
              <span class="text-3xl flex-shrink-0 mt-1" role="img" aria-hidden="true">{item.emoji}</span>
              <div>
                <h3 class="font-display text-lg text-lake-700 mb-2">{item.title}</h3>
                <p class="font-body text-neutral text-sm leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑦ CONSEJOS DE PESCA -->
    <section class="section-padding bg-white" id="consejos" data-section="pesca-consejos">
      <div class="section-container">
        <h2 class="section-heading reveal">Consejos para pescar mejor</h2>
        <p class="section-subtitle reveal stagger-1">
          No necesitas ser experto, pero estos tips te dan ventaja desde el primer lanzamiento.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto reveal stagger-2">
          {[
            {
              title: 'Las mañanas son mejores',
              tip: 'Entre 9 AM y 11 AM el lago está más tranquilo y los peces más activos. Si buscas Yamu, llega temprano.',
            },
            {
              title: 'Cada especie tiene su carnada',
              tip: 'Masa para Tilapias, lombriz para Dorada y Cachama, carnada viva para Yamu. Pregúntanos al llegar y te orientamos.',
            },
            {
              title: 'El Yamu requiere paciencia',
