---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Reviews from '../../../components/Reviews.astro';
import StarRating from '../../../components/StarRating.astro';
import PescaFAQ from '../../../components/PescaFAQ.astro';
import Eyebrow from '../../../components/ui/Eyebrow.astro';
import SectionHeading from '../../../components/ui/SectionHeading.astro';
import Button from '../../../components/ui/Button.astro';
import LinkRule from '../../../components/ui/LinkRule.astro';
import { sanityClient, urlFor, responsiveImage } from '../../../lib/sanity';
import { FISH_SPECIES_QUERY } from '../../../lib/queries/fishSpecies';
import { HERO_SECTION_QUERY } from '../../../lib/queries/heroSection';

const speciesData = await sanityClient.fetch(FISH_SPECIES_QUERY);
const hero = await sanityClient.fetch(HERO_SECTION_QUERY);

const heroImg = hero?.backgroundImage
  ? responsiveImage(hero.backgroundImage, [640, 1024, 1600, 1920], '100vw')
  : { src: '/images/hero/lago-comedor-vista.jpg', srcset: '', sizes: '' };

const WA_NUMBER = '573194313781';
const WA_MESSAGE = 'Hola, quiero reservar una visita de pesca deportiva en Laguna Escondida';
const waHref = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MESSAGE)}`;

const speciesExtra: Record<string, { flavor: string; technique: string; avgWeight: string }> = {
  'Yamu': {
    flavor: 'Carne firme e intensa. El favorito para preparar en ceviche o frito con patacones.',
    technique: 'Carnada viva o señuelo. Puede tardar 1–2 horas antes de picar — el reto que vale la pena.',
    avgWeight: '2–5 kg',
  },
  'Dorada': {
    flavor: 'Carne blanca, suave y delicada. Perfecta frita entera o al ajillo con limón.',
    technique: 'Lombriz o masa. Suele picar en los primeros 15–30 minutos.',
    avgWeight: '300–800 g',
  },
  'Cachama': {
    flavor: 'Carne jugosa con sabor profundo. Excelente asada, frita o en sancocho campestre.',
    technique: 'Frutas (mango, guayaba) o maíz partido. Más activa al mediodía.',
    avgWeight: '1–3 kg',
  },
  'Tilapia Roja': {
    flavor: 'Carne blanca y suave, absorbe muy bien salsas y aliños. La preferida de los niños.',
    technique: 'Masa o lombriz. La más activa del lago — ideal para principiantes.',
    avgWeight: '300–700 g',
  },
  'Tilapia Nilotica': {
    flavor: 'Textura firme, sabor limpio. Muy apreciada frita entera con arroz y patacón.',
    technique: 'Masa o pan. Pica con frecuencia, buena opción cuando hay poca actividad.',
    avgWeight: '400–900 g',
  },
};

const difficultyLabel: Record<string, string> = {
  Facil: 'Fácil',
  Media: 'Media',
  Dificil: 'Difícil',
};

const differentiators = [
  {
    label: '01',
    title: '5 especies en un solo lago',
    body: 'Mientras la mayoría de trucheras solo ofrecen una especie, aquí puedes pescar cinco — cada visita es una experiencia diferente.',
  },
  {
    label: '02',
    title: 'Para todos los niveles',
    body: 'Niños desde 4 años, principiantes y pescadores con experiencia. Caña, carnada y orientación incluidas — solo traes las ganas.',
  },
  {
    label: '03',
    title: 'Del agua a tu plato',
    body: 'Lo que pesques, el restaurante lo prepara fresco. No hay nada más campestre que comer tu propia captura frente al lago.',
  },
];

const steps = [
  {
    step: '01',
    title: 'Llegada',
    description: 'Parqueas, entras y te recibimos con orientación del lugar. Te explicamos las zonas del lago y las especies disponibles.',
  },
  {
    step: '02',
    title: 'Elige tu puesto',
    description: 'Seleccionas tu zona en el lago. Hay puestos al sol, a la sombra y kioscos privados para grupos con reserva anticipada.',
  },
  {
    step: '03',
    title: 'Pesca',
    description: 'Caña y carnada básica incluidas. Nuestro equipo está disponible para ayudarte a pescar tu primera o décima captura.',
  },
  {
    step: '04',
    title: 'A la mesa',
    description: 'El restaurante prepara tu captura fresca o pides del menú. Una vista al lago, comida campestre y el sabor de lo que pescaste.',
  },
];

const includes = [
  'Acceso al lago de pesca deportiva',
  'Caña de pescar y carnada básica',
  'Orientación inicial para nuevos pescadores',
  'Asistencia del equipo durante la jornada',
  'Parqueadero gratuito',
  'Zonas de descanso y mesas al aire libre',
];

const extras = [
  'Preparación de tu captura en el restaurante',
  'Carnadas especiales para Yamu (mayor reto)',
  'Kiosco privado para grupos (reserva anticipada)',
  'Menú completo del restaurante campestre',
  'Bebidas, jugos naturales y postres',
  'Servicio de foto con tu captura',
];

const audiences = [
  {
    label: 'Familias',
    title: 'Familias con niños',
    description: 'Niños desde 4 años pueden pescar sin problema. El ambiente es seguro, tranquilo y lejos del ruido de la ciudad. Una forma diferente de pasar el fin de semana en familia.',
  },
  {
    label: 'Parejas',
    title: 'Parejas',
    description: 'Un plan diferente. Naturaleza, tranquilidad y la complicidad de esperar juntos a que pique. Luego un almuerzo frente al lago con lo que pescaron.',
  },
  {
    label: 'Grupos',
    title: 'Grupos de amigos',
    description: 'Competencia sana: quién pesca más, quién pesca el más grande. Con kiosco privado disponible para grupos que quieran su espacio exclusivo.',
  },
  {
    label: 'Expertos',
    title: 'Pescadores con experiencia',
    description: 'El Yamu es el reto. Difícil de pescar, espectacular al comerlo. Si ya dominas la trucha, ven a buscar algo que te haga sudar.',
  },
];

const tips = [
  {
    title: 'Las mañanas son mejores',
    tip: 'Entre 9 AM y 11 AM el lago está más tranquilo y los peces más activos. Si buscas Yamu, llega temprano.',
  },
  {
    title: 'Cada especie tiene su carnada',
    tip: 'Masa para Tilapias, lombriz para Dorada y Cachama, carnada viva para Yamu. Pregúntanos al llegar y te orientamos.',
  },
  {
    title: 'El Yamu requiere paciencia',
    tip: 'Puede tardar hasta 2 horas antes de picar. No desesperes — cuando muerde, la adrenalina vale cada minuto de espera.',
  },
  {
    title: 'Días nublados = más actividad',
    tip: 'Con cielo nublado y temperatura fresca, los peces se mueven más. Los días soleados intensos los vuelven menos activos.',
  },
  {
    title: 'Para niños: empieza cerca a la orilla',
    tip: 'La Tilapia Roja es la más activa y abundante cerca a la orilla. Perfecta para que los pequeños tengan su primera captura rápido.',
  },
  {
    title: 'Guarda calma en el puesto',
    tip: 'El ruido y movimiento espantan los peces. Habla en voz baja, evita golpear el suelo y deja que el agua se calme antes de lanzar.',
  },
];

const PAGE_TITLE = 'Pesca Deportiva en Marinilla — 5 especies | Laguna Escondida';
const PAGE_DESCRIPTION = 'Pesca Yamu, Dorada, Cachama, Tilapia Roja y Nilotica en un lago privado. La mayor variedad del Oriente Antioqueño, a 45 min de Medellín. Para todos los niveles.';
---

<BaseLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION}>
  <Navbar />
  <main>

    <!-- ① HERO -->
    <section class="pesca-hero" id="inicio" data-section="pesca-hero" data-screen-label="Pesca hero">
      <div class="hero-bg">
        <img
          src={heroImg.src}
          srcset={heroImg.srcset}
          sizes={heroImg.sizes}
          alt="Lago de pesca deportiva en Laguna Escondida, Marinilla, Antioquia"
          class="hero-img"
          loading="eager"
          fetchpriority="high"
          data-parallax
        />
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-inner">
        <div class="hero-content">
          <Eyebrow text="Pesca deportiva · Lago privado" inverse />
          <h1 class="hero-title">
            Pesca 5 especies.<br />
            Ninguna truchera<br />
            <em>las tiene todas.</em>
          </h1>
          <p class="hero-lead">
            Yamu, Dorada, Cachama, Tilapia Roja y Nilotica en un lago privado en Marinilla.
            No se necesita experiencia previa — traes ganas, nosotros ponemos el resto.
          </p>

          <div class="hero-actions">
            <Button
              variant="inverse-primary"
              href={waHref}
              event="whatsapp_click"
              location="pesca-hero"
              withDot
            >
              Reservar por WhatsApp
            </Button>
            <Button variant="inverse-secondary" href="#como-funciona">
              Ver cómo funciona
            </Button>
          </div>

          <div class="hero-trust">
            <StarRating />
            <span>4.6 en Google Maps · Marinilla, Antioquia</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ② DIFERENCIADORES -->
    <section class="pesca-section" id="diferenciadores" data-section="pesca-diferenciadores" data-screen-label="Diferenciadores">
      <div class="section-container">
        <SectionHeading
          eyebrow="Por qué aquí"
          title="¿Por qué pescar en Laguna Escondida?"
          subtitle="No somos una truchera más. Somos el lago con más variedad de especies del Oriente Antioqueño, en un ambiente campestre donde la pesca y la gastronomía van de la mano."
          class="reveal"
        />

        <div class="diff-grid reveal stagger-1">
          {differentiators.map((d) => (
            <article class="diff-card">
              <div class="diff-index">{d.label}</div>
              <h3 class="diff-title">{d.title}</h3>
              <p class="diff-body">{d.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ③ LAS 5 ESPECIES -->
    <section class="pesca-section pesca-section--tint" id="especies" data-section="pesca-especies" data-screen-label="Especies">
      <div class="section-container">
        <SectionHeading
          eyebrow="Lo que vive en el lago"
          title="Las 5 especies que puedes pescar"
          subtitle="Cada especie tiene su propio carácter: algunas pican rápido, otras son todo un reto. Todas terminan en un plato delicioso si así lo quieres."
          class="reveal"
        />

        <div class="species-list reveal stagger-1">
          {speciesData.map((species: any) => {
            const extra = speciesExtra[species.name] ?? {
              flavor: species.description,
              technique: 'Consulta con nuestro equipo al llegar.',
              avgWeight: '—',
            };
            return (
              <article class="species-card">
                {species.image && (
                  <div class="species-media">
                    <img
                      src={urlFor(species.image).width(400).height(500).fit('crop').url()}
                      alt={species.image?.alt || species.name}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="species-body">
                  <header class="species-head">
                    <h3 class="species-name">{species.name}</h3>
                    <dl class="species-meta">
                      <div>
                        <dt>Dificultad</dt>
                        <dd>{difficultyLabel[species.difficulty] ?? species.difficulty}</dd>
                      </div>
                      <div>
                        <dt>Peso promedio</dt>
                        <dd>{extra.avgWeight}</dd>
                      </div>
                    </dl>
                  </header>
                  <div class="species-split">
                    <div>
                      <p class="species-label">Sabor</p>
                      <p class="species-copy">{extra.flavor}</p>
                    </div>
                    <div>
                      <p class="species-label">Técnica recomendada</p>
                      <p class="species-copy">{extra.technique}</p>
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ④ CÓMO FUNCIONA -->
    <section class="pesca-section" id="como-funciona" data-section="pesca-como-funciona" data-screen-label="Como funciona">
      <div class="section-container">
        <SectionHeading
          eyebrow="La experiencia"
          title="¿Cómo es la experiencia?"
          subtitle="Sin complicaciones. Llegas, pescas y comes. Así de sencillo."
          class="reveal"
        />

        <div class="steps-grid reveal stagger-1">
          {steps.map((s) => (
            <article class="step-card">
              <div class="step-index">{s.step}</div>
              <h3 class="step-title">{s.title}</h3>
              <p class="step-body">{s.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤ QUÉ INCLUYE -->
    <section class="pesca-section pesca-section--olive" id="incluye" data-section="pesca-incluye" data-screen-label="Incluye">
      <div class="section-container">
        <SectionHeading
          eyebrow="Lo que cubrimos"
          title="¿Qué incluye la visita?"
          subtitle="Todo lo que necesitas para pescar está cubierto desde que llegas."
          class="reveal"
        />

        <div class="includes-grid reveal stagger-1">
          <div class="includes-card">
            <p class="includes-label">Incluido</p>
            <ul class="includes-list">
              {includes.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="includes-card includes-card--muted">
            <p class="includes-label">Adicionales</p>
            <ul class="includes-list includes-list--muted">
              {extras.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>

        <div class="includes-cta reveal stagger-2">
          <p class="includes-cta-lead">¿Preguntas sobre precios o disponibilidad?</p>
          <LinkRule
            href={waHref}
            label="Consultar por WhatsApp"
            event="whatsapp_click"
            location="pesca-incluye"
            target="_blank"
            rel="noopener"
          />
        </div>
      </div>
    </section>

    <!-- ⑥ PARA QUIÉN ES -->
    <section class="pesca-section pesca-section--tint" id="para-quien" data-section="pesca-para-quien" data-screen-label="Para quien">
      <div class="section-container">
        <SectionHeading
          eyebrow="Para ti"
          title="¿Para quién es esta experiencia?"
          subtitle="Laguna Escondida recibe a todo tipo de visitantes. Cada uno encuentra algo especial en el lago."
          class="reveal"
        />

        <div class="audience-grid reveal stagger-1">
          {audiences.map((a) => (
            <article class="audience-card">
              <p class="audience-tag">{a.label}</p>
              <h3 class="audience-title">{a.title}</h3>
              <p class="audience-body">{a.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑦ CONSEJOS DE PESCA -->
    <section class="pesca-section" id="consejos" data-section="pesca-consejos" data-screen-label="Consejos">
      <div class="section-container">
        <SectionHeading
          eyebrow="Apuntes del lago"
          title="Consejos para pescar mejor"
          subtitle="No necesitas ser experto, pero estos tips te dan ventaja desde el primer lanzamiento."
          class="reveal"
        />

        <div class="tips-grid reveal stagger-1">
          {tips.map((t) => (
            <article class="tip-card">
              <h3 class="tip-title">{t.title}</h3>
              <p class="tip-body">{t.tip}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑧ REVIEWS -->
    <Reviews />

    <!-- ⑨ FAQ -->
    <PescaFAQ />

    <!-- ⑩ CTA FINAL -->
    <section class="pesca-cta-final" id="reservar" data-section="pesca-cta-final" data-screen-label="CTA final">
      <div class="cta-container">
        <div class="cta-text reveal">
          <Eyebrow text="Reserva tu visita" inverse />
          <h2 class="cta-heading">¿Listo para pescar <em>Yamu</em>?</h2>
          <p class="cta-lead">
            Reserva tu visita por WhatsApp. Te confirmamos disponibilidad en minutos
            y te damos todo lo que necesitas saber antes de llegar.
          </p>
        </div>
        <div class="cta-actions reveal stagger-1">
          <Button
            variant="inverse-primary"
            href={waHref}
            event="whatsapp_click"
            location="pesca-cta-final"
            withDot
          >
            Reservar ahora
          </Button>
          <Button variant="inverse-secondary" href="/">
            Ver otras experiencias
          </Button>
        </div>
        <p class="cta-note reveal stagger-2">
          Sábados, domingos y festivos · 9:00 AM – 6:00 PM · Vereda La Primavera, Marinilla
        </p>
      </div>
    </section>

  </main>

  <a
    id="wa-floating-btn"
    href={waHref}
    class="wa-floating"
    aria-label="Contactar por WhatsApp"
    data-event="whatsapp_click" data-location="floating"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <Footer />
</BaseLayout>

<script is:inline>
  (function() {
    var img = document.querySelector('[data-parallax]');
    if (!img || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          img.style.transform = 'translateY(' + (window.scrollY * -0.15) + 'px)';
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<style>
  /* ── Hero ── */
  .pesca-hero {
    position: relative;
    min-height: 92vh;
    padding-top: 120px;
    padding-bottom: 80px;
    overflow: hidden;
    color: var(--color-sand-50);
    background: var(--color-lake-800);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(7, 19, 14, 0) 0%,
      rgba(7, 19, 14, 0.15) 30%,
      rgba(7, 19, 14, 0.72) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    min-height: calc(92vh - 200px);
    display: flex;
    align-items: flex-end;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 720px;
  }

  .hero-title {
    margin-top: 24px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 6.2vw, 5.25rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-sand-50);
    max-width: 18ch;
  }

  .hero-title em {
    font-style: italic;
    color: var(--color-earth-300);
    font-weight: 300;
  }

  .hero-lead {
    margin-top: 24px;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.8);
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
    font-size: var(--text-body-sm);
    color: rgba(250, 248, 243, 0.7);
  }

  /* ── Section containers ── */
  .pesca-section {
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
  }

  .pesca-section--tint {
    background: var(--color-surface-tint);
  }

  .pesca-section--olive {
    background: var(--color-olive-50);
  }

  .section-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  /* ── Diferenciadores ── */
  .diff-grid {
    margin-top: 64px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 900px) {
    .diff-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 56px;
    }
  }

  .diff-card {
    padding-top: 24px;
    border-top: 1px solid var(--color-line-gold, var(--color-earth-300));
  }

  .diff-index {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-ink);
  }

  .diff-title {
    margin: 18px 0 12px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    line-height: 1.15;
    color: var(--color-ink);
  }

  .diff-body {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  /* ── Especies list ── */
  .species-list {
    margin-top: 64px;
    display: flex;
