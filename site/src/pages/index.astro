---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ExperienceCards from '../components/ExperienceCards.astro';
import FishSpecies from '../components/FishSpecies.astro';
import QuickGallery from '../components/QuickGallery.astro';
import Reviews from '../components/Reviews.astro';
import LocationMap from '../components/LocationMap.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);
---

<BaseLayout
  title={t.meta.homeTitle}
  description={t.meta.homeDescription}
>
  <Navbar />
  <main>
    <Hero />
    <ExperienceCards />
    <FishSpecies />
    <QuickGallery />
    <Reviews />
    <LocationMap />
    <BlogPreview />
  </main>
  <Footer />
</BaseLayout>
