---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Eyebrow from '../../../components/ui/Eyebrow.astro';
import LinkRule from '../../../components/ui/LinkRule.astro';
import { sanityClient, responsiveImage } from '../../../lib/sanity';
import type { BlogCategory, BlogPostListItem } from '../../../lib/queries/blog';
import { useTranslations, getDateLocale, type Locale } from '../../../i18n';

export async function getStaticPaths() {
  const categories = await sanityClient.fetch<BlogCategory[]>(`*[_type == "blogCategory" && defined(slug.current)] {
    title,
    slug,
    badgeClass
  }`);
  const allPosts = await sanityClient.fetch<BlogPostListItem[]>(`*[_type == "blogPost"] | order(publishedAt desc) {
    title,
    slug,
    excerpt,
    featuredImage,
    publishedAt,
    author,
    "category": category->{title, slug, badgeClass}
  }`);
  return categories.map((cat) => ({
    params: { slug: cat.slug.current },
    props: {
      category: cat,
      posts: allPosts.filter((p) => p.category?.slug?.current === cat.slug.current),
    },
  }));
}

const { category, posts } = Astro.props as { category: BlogCategory; posts: BlogPostListItem[] };
const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);
const dateLocale = getDateLocale(locale);

const dateFmt = new Intl.DateTimeFormat(dateLocale, {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
const formatDate = (iso?: string) => {
  if (!iso) return '';
  try {
    return dateFmt.format(new Date(iso)).replace(/\./g, '');
  } catch {
    return '';
  }
};
---

<BaseLayout
  title={`${category.title} ${t.meta.categoryTitleSuffix}`}
  description={`${t.meta.categoryDescriptionPrefix} ${category.title.toLowerCase()} ${t.meta.categoryDescriptionSuffix}`}
>
  <Navbar />

  <header class="cat-hero" data-section="blog-category-hero" data-screen-label="Blog category hero">
    <div class="hero-container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/contenido">Blog</a>
        <span aria-hidden="true">/</span>
        <span class="is-current">{category.title}</span>
      </nav>

      <div class="hero-content reveal">
        <Eyebrow text="Categoría" />
        <h1 class="hero-title">{category.title}</h1>
        <p class="hero-lead">{t.blog.allArticlesIn} <em>{category.title}</em>.</p>
      </div>
    </div>
  </header>

  <main class="cat-list-section" data-section="blog-category-list" data-screen-label="Blog category list">
    <div class="section-container">
      {posts.length > 0 ? (
        <div class="blog-grid reveal">
          {posts.map((post) => {
            const imgAttrs = responsiveImage(
              post.featuredImage,
              [400, 800, 1200],
              '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw',
            );
            const date = formatDate(post.publishedAt);
            return (
              <a
                class="blog-card"
                href={`/contenido/${post.slug.current}`}
                data-event="blog_card_click"
                data-location="blog-category"
              >
                <div class="blog-media">
                  <img
                    src={imgAttrs.src}
                    srcset={imgAttrs.srcset}
                    sizes={imgAttrs.sizes}
                    alt={post.featuredImage?.alt || post.title}
                    loading="lazy"
                  />
                </div>
                {post.category?.title && (
                  <p class="blog-tag">{post.category.title}</p>
                )}
                <h2 class="blog-heading">{post.title}</h2>
                {post.excerpt && <p class="blog-excerpt">{post.excerpt}</p>}
                {date && <p class="blog-meta">{date}</p>}
              </a>
            );
          })}
        </div>
      ) : (
        <p class="blog-empty">{t.blog.categoryEmptyState}</p>
      )}

      <div class="back-cta">
        <LinkRule
          href="/contenido"
          label={t.blog.backToBlog}
          event="blog_back_click"
          location="blog-category"
        />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .cat-hero {
    position: relative;
    padding-block: clamp(100px, 12vw, 160px) clamp(60px, 8vw, 100px);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
  }

  .hero-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .breadcrumb {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
    margin-bottom: 48px;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-3, 200ms) var(--ease-out);
  }

  .breadcrumb a:hover {
    color: var(--color-ink);
  }

  .breadcrumb .is-current {
    color: var(--color-accent-ink, var(--color-earth-400));
  }

  .hero-content {
    max-width: 720px;
    display: grid;
    gap: 20px;
  }

  .hero-title {
    margin: 16px 0 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    max-width: 22ch;
  }

  .hero-lead {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 52ch;
  }

  .hero-lead em {
    font-style: italic;
    color: var(--color-lake-700);
  }

  .cat-list-section {
    padding-block: clamp(60px, 8vw, 100px);
    background: var(--color-surface);
  }

  .section-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 720px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px;
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }
  }

  .blog-card {
    display: grid;
    gap: 16px;
    text-decoration: none;
    color: inherit;
  }

  .blog-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-tint);
  }

  .blog-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out);
  }

  .blog-card:hover .blog-media img {
    transform: scale(1.04);
  }

  .blog-tag {
    margin: 4px 0 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-ink, var(--color-earth-400));
  }

  .blog-heading {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.25;
    color: var(--color-ink);
    transition: color var(--duration-3, 200ms) var(--ease-out);
  }

  .blog-card:hover .blog-heading {
    color: var(--color-lake-700);
  }

  .blog-excerpt {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-sm);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .blog-meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }

  .blog-empty {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink-muted);
  }

  .back-cta {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid var(--color-line);
    display: flex;
    justify-content: center;
  }
</style>
