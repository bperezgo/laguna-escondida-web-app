---
import { sanityClient, responsiveImage } from '../lib/sanity';
import {
  EXPERIENCES_SECTION_QUERY,
  EXPERIENCES_QUERY,
  type ExperiencesSectionData,
  type ExperienceCard,
} from '../lib/queries/experiences';
import SectionHeading from './ui/SectionHeading.astro';
import LinkRule from './ui/LinkRule.astro';

const [section, cards] = await Promise.all([
  sanityClient.fetch<ExperiencesSectionData | null>(EXPERIENCES_SECTION_QUERY),
  sanityClient.fetch<ExperienceCard[]>(EXPERIENCES_QUERY),
]);
---

<section
  class="experiences-section"
  id="experiencias"
  data-section="experiencias"
  data-screen-label="Experiencias"
>
  <div class="experiences-container">
    <SectionHeading
      eyebrow={section?.eyebrow ?? ''}
      title={section?.heading ?? ''}
      subtitle={section?.subtitle ?? ''}
      withRule
      class="reveal"
    />

    <div class="exp-grid reveal">
      {cards.map((card, i) => {
        const imgAttrs = responsiveImage(
          card.image,
          [400, 800, 1200, 1600],
          '(max-width: 720px) 100vw, (max-width: 1024px) 50vw, 33vw',
        );
        const alt = card.image?.alt ?? card.title;
        return (
          <article class={`exp-card stagger-${i + 1}`}>
            <div class="media">
              <span class="num">{card.label}</span>
              <img
                class="ph"
                src={imgAttrs.src}
                srcset={imgAttrs.srcset}
                sizes={imgAttrs.sizes}
                alt={alt}
                loading="lazy"
                decoding="async"
              />
              <div class="ph-overlay" aria-hidden="true"></div>
            </div>
            <div class="body-wrap">
              <h3 class="h4-editorial">
                {card.title}<br />
                <em>{card.italicSubtitle}</em>
              </h3>
              <p class="body-editorial">{card.description}</p>
              <div class="meta">
                <span>
                  {card.metaLeftLabel} <b class="gold">{card.metaLeftValue}</b>
                </span>
                <span>{card.metaRight}</span>
              </div>
              <LinkRule
                href={`/experiencias/${card.slug}/`}
                label={card.cta}
                event={card.eventKey}
                location="experiences"
              />
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .experiences-section {
    padding-block: clamp(80px, 10vw, 160px);
    background: var(--color-sand-50);
    border-top: 1px solid var(--color-line);
  }

  .experiences-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .exp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    margin-top: 64px;
  }

  @media (min-width: 720px) {
    .exp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .exp-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
  }

  .exp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform var(--duration-3) var(--ease-out);
  }

  .media {
    position: relative;
    clip-path: inset(0 round 999px 999px 8px 8px);
    isolation: isolate;
  }

  .ph {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    transition: transform var(--duration-4) var(--ease-out), filter var(--duration-3) var(--ease-out);
    background-color: var(--color-lake-700);
  }

  .ph-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(7, 19, 14, 0.35) 0%, rgba(7, 19, 14, 0) 30%, rgba(7, 19, 14, 0) 70%, rgba(7, 19, 14, 0.35) 100%);
  }

  .exp-card:hover .ph {
    transform: scale(1.03);
    filter: brightness(0.96);
  }

  .num {
    position: absolute;
    bottom: 20px;
    left: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-sand-50);
    z-index: 2;
    padding: 6px 10px;
    background: rgba(14, 32, 25, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .body-wrap {
    padding-top: 28px;
    display: grid;
    gap: 14px;
  }

  .body-wrap h3 {
    margin: 0;
  }

  .body-wrap h3 em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-lake-500);
    font-weight: 300;
  }

  .body-editorial {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding-top: 18px;
    margin-top: 6px;
    border-top: 1px solid var(--color-line);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-ink-muted);
    text-transform: uppercase;
  }

  .meta .gold {
    color: var(--color-earth-400);
    font-family: var(--font-serif);
    font-size: 14px;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 500;
  }
</style>
