---
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';

const WA_NUMBER = '573194313781';
const WA_MESSAGE = 'Hola, quiero hacer una reserva de evento en Laguna Escondida. ¿Tienen disponibilidad?';
const waHref = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MESSAGE)}`;
---

<section class="eventos-cta" id="cta-eventos" data-section="eventos-cta" data-screen-label="CTA eventos">
  <div class="cta-container">
    <div class="cta-text reveal">
      <Eyebrow text="Reserva tu fecha" inverse />
      <h2 class="cta-heading">
        Los mejores momentos pasan<br />
        <em>en lugares especiales.</em>
      </h2>
      <p class="cta-lead">
        Las fechas en temporada alta se agotan rápido. Consulta disponibilidad
        hoy y asegura el día que sueñas.
      </p>
    </div>

    <div class="cta-actions reveal stagger-1">
      <Button
        variant="inverse-primary"
        href="/f/celebraciones/"
        event="eventos_ver_paquetes"
        location="cta-final"
        withDot
      >
        Ver paquetes y disponibilidad
      </Button>
      <Button
        variant="inverse-secondary"
        href={waHref}
        event="whatsapp_click"
        location="eventos-cta"
        target="_blank"
        rel="noopener"
      >
        Consultar disponibilidad
      </Button>
    </div>

    <p class="cta-note reveal stagger-2">
      Sin compromiso de pago hasta confirmar la fecha · Visita previa sin costo
    </p>
  </div>
</section>

<style>
  .eventos-cta {
    position: relative;
    overflow: hidden;
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-lake-800);
    color: var(--color-sand-50);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    text-align: center;
  }

  .eventos-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px 300px at 50% 50%,
      rgba(197, 169, 97, 0.1),
      transparent 60%
    );
    pointer-events: none;
  }

  .cta-container {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    padding-inline: var(--gutter);
    display: grid;
    gap: 32px;
    justify-items: center;
  }

  .cta-heading {
    margin: 16px 0 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-sand-50);
    max-width: 22ch;
  }

  .cta-heading em {
    font-style: italic;
    color: var(--color-earth-300);
    font-weight: 300;
  }

  .cta-lead {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.78);
    max-width: 48ch;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }

  .cta-note {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.4);
  }
</style>
