---
import Eyebrow from '../ui/Eyebrow.astro';
import ArchImage from '../ui/ArchImage.astro';

const amenidades = [
  'Ramada cubierta con capacidad para 80 personas',
  'Acceso privado al lago durante el evento',
  'Zona de fogón para asados',
  'Cocina equipada disponible',
  'Parqueadero privado con amplia capacidad',
  'Baños y vestier para invitados',
  'Zona de pesca recreativa para los invitados',
  'Área verde para actividades y juegos',
  'Acceso a sistema de sonido (con paquetes)',
];

const stats = [
  { valor: '80', unidad: 'personas', descripcion: 'Capacidad máxima' },
  { valor: '2.000', unidad: 'm²', descripcion: 'Área total' },
  { valor: '100', unidad: '%', descripcion: 'Espacio exclusivo' },
];
---

<section class="espacio-section" id="el-espacio" data-section="eventos-espacio" data-screen-label="El espacio">
  <div class="espacio-container">
    <div class="espacio-grid">
      <div class="espacio-text">
        <Eyebrow text="El espacio" />
        <h2 class="espacio-title reveal">
          Un lugar para que tus invitados<br />
          <em>no quieran irse.</em>
        </h2>
        <p class="espacio-lead reveal stagger-1">
          Laguna Escondida se adapta a tu evento: el espacio es tuyo. Sin otras mesas,
          sin extraños. Solo tu familia, tus amigos y el lago.
        </p>

        <ul class="amenidades-list reveal stagger-2">
          {amenidades.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="espacio-side reveal stagger-1">
        <div class="espacio-media">
          <ArchImage
            src="/images/hero/lago-comedor-vista.jpg"
            alt="Ramada y lago en Laguna Escondida para eventos privados"
            variant="arch-soft"
            ratio="3x4"
          />
          <figcaption class="media-caption">
            <span class="idx">01</span>
            <span>Vereda La Primavera · Marinilla, Antioquia</span>
          </figcaption>
        </div>

        <dl class="espacio-stats">
          {stats.map((s) => (
            <div>
              <dt>{s.descripcion}</dt>
              <dd>
                <span class="val">{s.valor}</span>
                {s.unidad && <span class="unit">{s.unidad}</span>}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .espacio-section {
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
  }

  .espacio-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .espacio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .espacio-grid {
      grid-template-columns: 6fr 5fr;
      gap: 96px;
    }
  }

  .espacio-title {
    margin: 20px 0 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    max-width: 22ch;
  }

  .espacio-title em {
    font-style: italic;
    color: var(--color-lake-700);
    font-weight: 300;
  }

  .espacio-lead {
    margin: 24px 0 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 52ch;
  }

  .amenidades-list {
    margin: 32px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
    border-top: 1px solid var(--color-line);
    padding-top: 24px;
  }

  .amenidades-list li {
    position: relative;
    padding-left: 24px;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--color-ink);
  }

  .amenidades-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 12px;
    height: 1px;
    background: var(--color-earth-300);
  }

  .espacio-side {
    display: grid;
    gap: 32px;
  }

  .espacio-media {
    display: grid;
    gap: 12px;
  }

  .media-caption {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-ink-subtle);
  }

  .media-caption .idx {
    color: var(--color-accent-ink);
  }

  .espacio-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin: 0;
    padding-top: 24px;
    border-top: 1px solid var(--color-line);
  }

  .espacio-stats > div {
    display: grid;
    gap: 8px;
  }

  .espacio-stats dt {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-subtle);
  }

  .espacio-stats dd {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .espacio-stats .val {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1;
    color: var(--color-lake-700);
  }

  .espacio-stats .unit {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
</style>
