---
import SectionHeading from '../ui/SectionHeading.astro';

const tipos = [
  {
    label: '01',
    titulo: 'Cumpleaños y quinceañeras',
    descripcion: 'Un día inolvidable junto al lago, con espacio para decoración, música y el menú que elijas.',
  },
  {
    label: '02',
    titulo: 'Reuniones familiares',
    descripcion: 'Reencuentros, integración y comida campestre al aire libre rodeados de peces y naturaleza.',
  },
  {
    label: '03',
    titulo: 'Eventos corporativos',
    descripcion: 'Team buildings, retiros y celebraciones de empresa en un entorno natural que inspira.',
  },
  {
    label: '04',
    titulo: 'Bodas y aniversarios',
    descripcion: 'Ceremonias íntimas con el lago como fondo. Naturaleza, privacidad y un ambiente único.',
  },
  {
    label: '05',
    titulo: 'Grados y celebraciones',
    descripcion: 'Despide una etapa con familia y amigos en un lugar que sale de lo ordinario.',
  },
  {
    label: '06',
    titulo: 'Fiestas temáticas',
    descripcion: 'Halloween, Navidad, cumpleaños temáticos — el entorno natural potencia cualquier decoración.',
  },
];
---

<section class="tipos-section" id="tipos-eventos" data-section="eventos-tipos" data-screen-label="Tipos de evento">
  <div class="section-container">
    <SectionHeading
      eyebrow="Ocasiones"
      title="¿Qué tipo de evento celebras?"
      subtitle="Desde una reunión íntima de familia hasta un evento corporativo — tenemos el espacio y la naturaleza para hacerlo especial."
      class="reveal"
    />

    <div class="tipos-grid reveal stagger-1">
      {tipos.map((t) => (
        <article class="tipo-card">
          <p class="tipo-index">{t.label}</p>
          <h3 class="tipo-title">{t.titulo}</h3>
          <p class="tipo-body">{t.descripcion}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .tipos-section {
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-surface-tint);
    border-top: 1px solid var(--color-line);
  }

  .section-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .tipos-grid {
    margin-top: 64px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 720px) {
    .tipos-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px;
    }
  }

  @media (min-width: 1024px) {
    .tipos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tipo-card {
    padding-top: 24px;
    border-top: 1px solid var(--color-line-gold, var(--color-earth-300));
  }

  .tipo-index {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-ink);
  }

  .tipo-title {
    margin: 16px 0 10px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    line-height: 1.15;
    color: var(--color-ink);
  }

  .tipo-body {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
</style>
