---
import SectionHeading from '../ui/SectionHeading.astro';

const pasos = [
  {
    numero: '01',
    titulo: 'Cuéntanos tu idea',
    descripcion: 'Escríbenos por WhatsApp o llena nuestro formulario de contacto. Cuéntanos la fecha, el número de personas y el tipo de evento.',
  },
  {
    numero: '02',
    titulo: 'Visita de reconocimiento',
    descripcion: 'Te invitamos a conocer el espacio antes de confirmar. Puedes venir con quien toma las decisiones y recorrer el lugar sin compromiso.',
  },
  {
    numero: '03',
    titulo: 'Armamos tu paquete',
    descripcion: 'Elegimos juntos el menú, los servicios incluidos y el horario. Separamos la fecha con un anticipo y listo.',
  },
  {
    numero: '04',
    titulo: 'Disfruta tu día',
    descripcion: 'El día del evento nosotros nos encargamos del espacio. Tú y tus invitados solo disfrutan.',
  },
];
---

<section class="funciona-section" id="como-funciona" data-section="eventos-como-funciona" data-screen-label="Como funciona">
  <div class="section-container">
    <SectionHeading
      eyebrow="El proceso"
      title="De la idea al recuerdo en cuatro pasos."
      subtitle="Sin complicaciones. Cada paso pensado para que solo te preocupes por disfrutar."
      class="reveal"
    />

    <div class="pasos-grid reveal stagger-1">
      {pasos.map((p) => (
        <article class="paso-card">
          <div class="paso-index">{p.numero}</div>
          <h3 class="paso-title">{p.titulo}</h3>
          <p class="paso-body">{p.descripcion}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .funciona-section {
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-surface-tint);
    border-top: 1px solid var(--color-line);
  }

  .section-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .pasos-grid {
    margin-top: 64px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 720px) {
    .pasos-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 48px;
    }
  }

  @media (min-width: 1024px) {
    .pasos-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  .paso-card {
    padding-top: 24px;
    border-top: 1px solid var(--color-line);
  }

  .paso-index {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: 3.25rem;
    line-height: 1;
    color: var(--color-earth-300);
  }

  .paso-title {
    margin: 16px 0 10px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .paso-body {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
</style>
