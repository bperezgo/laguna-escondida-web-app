---
const pasos = [
  {
    numero: '01',
    titulo: 'Cuéntanos tu idea',
    descripcion:
      'Escríbenos por WhatsApp o llena el formulario del funnel. Cuéntanos la fecha, el número de personas y el tipo de evento.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
  },
  {
    numero: '02',
    titulo: 'Visita de reconocimiento',
    descripcion:
      'Te invitamos a conocer el espacio antes de confirmar. Puedes venir con quien toma las decisiones y recorrer el lugar sin compromiso.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
  },
  {
    numero: '03',
    titulo: 'Armamos tu paquete',
    descripcion:
      'Elegimos juntos el menú, los servicios incluidos y el horario. Separamos la fecha con un anticipo y listo.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
  },
  {
    numero: '04',
    titulo: 'Disfruta tu día',
    descripcion:
      'El día del evento nosotros nos encargamos del espacio. Tú y tus invitados solo disfrutan.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  },
];
---

<section class="section-padding bg-sand-100" id="como-funciona" data-section="eventos-como-funciona">
  <div class="section-container">

    <h2 class="section-heading reveal">¿Cómo funciona?</h2>
    <p class="section-subtitle reveal stagger-1">
      De la idea al recuerdo en cuatro pasos.
    </p>

    <!-- Línea de tiempo -->
    <div class="relative">
      <!-- Línea conectora — solo visible en desktop -->
      <div class="hidden lg:block absolute top-14 left-0 right-0 h-0.5 bg-sand-200 z-0" aria-hidden="true"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative z-10">
        {pasos.map((paso, i) => (
          <div class={`flex flex-col items-center text-center reveal stagger-${i + 1}`}>
            <!-- Círculo con número -->
            <div class="w-16 h-16 rounded-full bg-lake-500 flex items-center justify-center mb-4 shadow-brand ring-4 ring-sand-100">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={paso.icono} />
              </svg>
            </div>
            <!-- Número de paso -->
            <span class="font-display text-xs text-earth-300 font-semibold tracking-widest mb-2">{paso.numero}</span>
            <h3 class="font-display text-xl text-lake-700 mb-2">{paso.titulo}</h3>
            <p class="font-body text-sm text-neutral/80 leading-relaxed">{paso.descripcion}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
