---
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';

const WA_NUMBER = '573194313781';
const WA_MESSAGE = 'Hola, me interesa realizar un evento en Laguna Escondida. ¿Me pueden dar más información?';
const waHref = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MESSAGE)}`;

const stats = [
  { label: 'Capacidad', value: 'hasta 80' },
  { label: 'Tipos de evento', value: '5+' },
  { label: 'Espacio', value: 'Privado' },
];
---

<section class="eventos-hero" id="inicio" data-section="eventos-hero" data-screen-label="Eventos hero">
  <div class="hero-bg">
    <img
      src="/images/hero/lago-comedor-vista.jpg"
      alt="Celebración campestre junto al lago en Laguna Escondida"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
      data-parallax
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-inner">
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span aria-hidden="true">/</span>
      <a href="/#experiencias">Experiencias</a>
      <span aria-hidden="true">/</span>
      <span class="is-current">Eventos</span>
    </nav>

    <div class="hero-content">
      <Eyebrow text="Eventos privados · Frente al lago" inverse />
      <h1 class="hero-title">
        Tu celebración,<br />
        <em>rodeada de naturaleza.</em>
      </h1>
      <p class="hero-lead">
        Eventos privados junto al lago en Marinilla, Antioquia — para familias que
        quieren algo diferente a un salón cualquiera.
      </p>

      <dl class="hero-meta">
        {stats.map((s) => (
          <div>
            <dt>{s.label}</dt>
            <dd>{s.value}</dd>
          </div>
        ))}
      </dl>

      <div class="hero-actions">
        <Button
          variant="inverse-primary"
          href="/f/celebraciones/"
          event="eventos_ver_paquetes"
          location="hero"
          withDot
        >
          Ver paquetes y disponibilidad
        </Button>
        <Button
          variant="inverse-secondary"
          href={waHref}
          event="whatsapp_click"
          location="eventos-hero"
          target="_blank"
          rel="noopener"
        >
          Preguntar por WhatsApp
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .eventos-hero {
    position: relative;
    min-height: 92vh;
    padding-top: 120px;
    padding-bottom: 80px;
    overflow: hidden;
    color: var(--color-sand-50);
    background: var(--color-lake-800);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(7, 19, 14, 0) 0%,
      rgba(7, 19, 14, 0.15) 30%,
      rgba(7, 19, 14, 0.75) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    min-height: calc(92vh - 200px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.55);
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .breadcrumb a {
    color: rgba(250, 248, 243, 0.7);
    text-decoration: none;
    transition: color var(--duration-3, 200ms) var(--ease-out);
  }

  .breadcrumb a:hover {
    color: var(--color-sand-50);
  }

  .breadcrumb .is-current {
    color: var(--color-earth-300);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 760px;
    margin-top: auto;
  }

  .hero-title {
    margin-top: 24px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-sand-50);
    max-width: 18ch;
  }

  .hero-title em {
    font-style: italic;
    color: var(--color-earth-300);
    font-weight: 300;
  }

  .hero-lead {
    margin-top: 24px;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.8);
    max-width: 52ch;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 40px;
    margin: 32px 0 0;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-meta > div {
    display: grid;
    gap: 6px;
  }

  .hero-meta dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(236, 242, 240, 0.55);
  }

  .hero-meta dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    color: var(--color-sand-50);
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 32px;
  }
</style>

<script is:inline>
  (function() {
    var img = document.querySelector('[data-parallax]');
    if (!img || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          img.style.transform = 'translateY(' + (window.scrollY * -0.15) + 'px)';
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();
</script>
