---
const waMessage = encodeURIComponent('Hola, me interesa realizar un evento en Laguna Escondida. ¿Me pueden dar más información?');
const waHref = `https://wa.me/573194313781?text=${waMessage}`;
---

<section class="relative min-h-[82vh] flex items-end" id="inicio" data-section="eventos-hero">
  <!-- Imagen de fondo — reemplazar con foto real de evento junto al lago -->
  <div class="absolute inset-0 overflow-hidden">
    <img
      src="/images/hero/lago-comedor-vista.jpg"
      alt="Celebración campestre junto al lago en Laguna Escondida"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-linear-to-t from-lake-700/90 via-lake-700/50 via-45% to-transparent to-75%"></div>
  </div>

  <div class="relative z-10 px-4 max-w-5xl mx-auto pb-14 sm:pb-24 w-full">

    <!-- Breadcrumb -->
    <nav class="mb-6 text-white/60 text-sm font-body hero-animate" aria-label="Ruta de navegación">
      <a href="/" class="hover:text-white transition-colors">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/#experiencias" class="hover:text-white transition-colors">Experiencias</a>
      <span class="mx-2">/</span>
      <span class="text-earth-300">Eventos</span>
    </nav>

    <!-- Etiqueta -->
    <span class="inline-block mb-4 px-3 py-1 bg-earth-300/20 border border-earth-300/40 rounded-full text-earth-300 text-xs font-body font-semibold tracking-widest uppercase hero-animate">
      Eventos privados
    </span>

    <!-- Headline -->
    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl text-white leading-tight text-shadow-hero hero-animate">
      Tu celebración,<br />
      <span class="text-earth-300">rodeada de naturaleza</span>
    </h1>

    <!-- Subheadline -->
    <p class="mt-5 text-base sm:text-xl text-white/85 font-body max-w-2xl text-shadow-hero hero-animate hero-animate-delay-1">
      Eventos privados junto al lago en Marinilla, Antioquia — para familias que
      quieren algo diferente a un salón cualquiera.
    </p>

    <!-- Stats rápidos -->
    <div class="flex flex-wrap gap-8 mt-7 mb-8 hero-animate hero-animate-delay-2">
      <div>
        <span class="block font-display text-3xl text-earth-300">hasta 80</span>
        <span class="font-body text-sm text-white/65">personas</span>
      </div>
      <div class="w-px bg-white/20 hidden sm:block self-stretch"></div>
      <div>
        <span class="block font-display text-3xl text-earth-300">5+</span>
        <span class="font-body text-sm text-white/65">tipos de eventos</span>
      </div>
      <div class="w-px bg-white/20 hidden sm:block self-stretch"></div>
      <div>
        <span class="block font-display text-3xl text-earth-300">100%</span>
        <span class="font-body text-sm text-white/65">espacio privado</span>
      </div>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 hero-animate hero-animate-delay-2">
      <a
        href="/f/celebraciones/"
        class="btn btn-lg bg-earth-300 hover:bg-earth-500 text-lake-700 border-0 font-body font-semibold text-base px-8"
        data-event="eventos_ver_paquetes" data-location="hero"
      >
        Ver paquetes y disponibilidad →
      </a>
      <a
        href={waHref}
        class="btn btn-lg btn-outline border-white text-white hover:bg-white/20 hover:border-white font-body font-semibold text-base px-8"
        data-event="whatsapp_click" data-location="eventos-hero"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Preguntar por WhatsApp
      </a>
    </div>

  </div>
</section>
