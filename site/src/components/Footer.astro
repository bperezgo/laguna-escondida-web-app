---
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);

const experienceLinks = [
  { href: '/experiencias/pesca-deportiva/', label: t.footer.sportFishing },
  { href: '/experiencias/restaurante/', label: t.footer.restaurant },
  { href: '/experiencias/eventos/', label: t.footer.events },
  { href: '/#galeria', label: t.footer.gallery },
  { href: '/contenido/', label: t.footer.blogLink },
];
---
<footer class="site-footer" data-screen-label="Footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="brandmark">
          <img src="/logo-navbar.png" alt="" width="32" height="32" class="brandmark-logo" />
          <span>{t.footer.brandName}</span>
        </span>
        <p class="tagline">{t.footer.tagline}</p>
        <p class="description">{t.footer.description}</p>
      </div>

      <div>
        <h6>{t.footer.experiencesTitle}</h6>
        <ul>
          {experienceLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h6>{t.footer.contactTitle}</h6>
        <ul>
          <li>{t.footer.address1}</li>
          <li>{t.footer.address2}</li>
          <li>
            <a
              href="https://wa.me/573194313781"
              data-event="whatsapp_click"
              data-location="footer"
            >
              {t.footer.whatsappLabel}
            </a>
          </li>
          <li>{t.footer.schedule}</li>
        </ul>
      </div>

      <div>
        <h6>{t.footer.followTitle}</h6>
        <ul class="social-list">
          <li>
            <a
              href="https://instagram.com/laguna_escondida_marinilla"
              target="_blank"
              rel="noopener"
              data-event="instagram_click"
              data-location="footer"
              aria-label="Instagram"
            >
              <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              <span>Instagram</span>
            </a>
          </li>
          <li>
            <a
              href="https://www.facebook.com/people/Laguna-Escondida/61580380932543/"
              target="_blank"
              rel="noopener"
              aria-label="Facebook"
            >
              <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              <span>Facebook</span>
            </a>
          </li>
          <li>
            <a
              href="https://maps.app.goo.gl/5EN4yjbr42zDCiyy6"
              target="_blank"
              rel="noopener"
              data-event="maps_click"
              data-location="footer"
              aria-label="Google Maps"
            >
              <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C7.31 0 3.5 3.81 3.5 8.5c0 6.625 8.5 15.5 8.5 15.5s8.5-8.875 8.5-15.5C20.5 3.81 16.69 0 12 0zm0 11.5a3 3 0 110-6 3 3 0 010 6z"/></svg>
              <span>Maps</span>
            </a>
          </li>
          <li>
            <a
              href="https://www.tiktok.com/@laguna.escondida7"
              target="_blank"
              rel="noopener"
              data-event="tiktok_click"
              data-location="footer"
              aria-label="TikTok"
            >
              <svg class="social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.54V6.78a4.85 4.85 0 01-1.02-.09z"/></svg>
              <span>TikTok</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{t.footer.copyright}</span>
      <span class="designed-note">{t.footer.designedNote}</span>
      <a href="/politica-de-privacidad/" class="privacy-link">{t.footer.privacy}</a>
    </div>
  </div>
</footer>

<a
  id="wa-floating-btn"
  href="https://wa.me/573194313781?text=Hola%2C%20quiero%20reservar%20en%20Laguna%20Escondida"
  class="wa-floating"
  data-event="whatsapp_click"
  data-location="floating"
  aria-label={t.footer.waFloatingLabel}
>
  <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<style>
  .site-footer {
    background: var(--color-lake-900);
    color: rgba(250, 248, 243, 0.7);
    padding: 80px var(--gutter) 40px;
  }

  .footer-inner {
    max-width: var(--container-width);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    padding-bottom: 56px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-brand .brandmark {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--color-sand-50);
    font-family: var(--font-display);
    font-size: 26px;
    letter-spacing: 0.02em;
  }

  .brandmark-logo {
    border-radius: 50%;
    display: block;
  }

  .footer-brand .tagline {
    margin: 24px 0 0;
    max-width: 34ch;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-body);
    line-height: 1.6;
    color: rgba(250, 248, 243, 0.85);
  }

  .footer-brand .description {
    margin: 16px 0 0;
    max-width: 40ch;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: 1.6;
    color: rgba(250, 248, 243, 0.55);
  }

  .footer-grid h6 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.5);
    margin: 0 0 20px;
    font-weight: 500;
  }

  .footer-grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: rgba(250, 248, 243, 0.7);
  }

  .footer-grid a {
    color: inherit;
    text-decoration: none;
    position: relative;
    display: inline-block;
    padding-bottom: 2px;
    transition: color var(--duration-2) var(--ease-out);
  }

  .footer-grid a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--color-earth-300);
    transition: right var(--duration-2) var(--ease-out);
  }

  .footer-grid a:hover {
    color: var(--color-sand-50);
  }

  .footer-grid a:hover::after {
    right: 0;
  }

  .social-list {
    gap: 14px !important;
  }

  .social-list a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .social-icon {
    width: 16px;
    height: 16px;
    color: var(--color-earth-300);
    flex-shrink: 0;
  }

  .footer-bottom {
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(250, 248, 243, 0.4);
    text-transform: uppercase;
  }

  .footer-bottom .designed-note {
    font-style: normal;
  }

  .privacy-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-2) var(--ease-out);
  }

  .privacy-link:hover {
    color: rgba(250, 248, 243, 0.75);
  }

  .wa-floating {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 50;
    width: 56px;
    height: 56px;
    background: #25d366;
    color: #ffffff;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    transition: transform var(--duration-2) var(--ease-out);
  }

  .wa-floating:hover {
    transform: scale(1.08);
  }

  .wa-floating svg {
    width: 28px;
    height: 28px;
  }
</style>
