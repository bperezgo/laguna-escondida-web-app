---
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);
---
<section class="section-padding bg-sand-gradient" id="ubicacion" data-section="ubicacion">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-display text-3xl md:text-4xl text-lake-700 text-center mb-4 reveal">
      {t.location.heading}
    </h2>
    <p class="text-center text-lg text-neutral mb-12 max-w-2xl mx-auto font-body reveal stagger-1">
      {t.location.subtitle}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start reveal stagger-2">

      <!-- Mapa -->
      <div class="rounded-brand overflow-hidden shadow-brand h-100">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.0!2d-75.3418145!3d6.1880394!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e46a10044cddb71%3A0x9db2b94ed46991da!2sLaguna%20Escondida!5e0!3m2!1ses!2sco!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={t.location.mapTitle}>
        </iframe>
      </div>

      <!-- Info de ubicacion -->
      <div class="space-y-6">
        <div class="card bg-white shadow-brand p-6">
          <h3 class="font-display text-xl text-lake-700 mb-3">{t.location.fromMedellin}</h3>
          <p class="font-body text-neutral" set:html={t.location.fromMedellinDesc} />
        </div>

        <div class="card bg-white shadow-brand p-6">
          <h3 class="font-display text-xl text-lake-700 mb-3">{t.location.fromRionegro}</h3>
          <p class="font-body text-neutral" set:html={t.location.fromRionegroDesc} />
        </div>

        <div class="card bg-white shadow-brand p-6">
          <h3 class="font-display text-xl text-lake-700 mb-3">{t.location.hours}</h3>
          <ul class="font-body text-neutral space-y-1">
            <li><strong>{t.location.hoursSatSun}</strong> {t.location.hoursSatSunTime}</li>
            <li><strong>{t.location.hoursHolidays}</strong> {t.location.hoursHolidaysTime}</li>
            <li><strong>{t.location.hoursWeekdays}</strong> {t.location.hoursWeekdaysTime}</li>
          </ul>
        </div>

        <a href="https://maps.google.com/?q=Laguna+Escondida+Marinilla"
           class="btn btn-primary btn-lg w-full text-white font-body font-semibold"
           target="_blank" rel="noopener"
           data-event="maps_click" data-location="directions">
          {t.location.openInMaps} &rarr;
        </a>
      </div>
    </div>
  </div>
</section>
