---
import SectionHeading from './ui/SectionHeading.astro';
import LinkRule from './ui/LinkRule.astro';
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);
---

<section
  class="location-section"
  id="ubicacion"
  data-section="ubicacion"
  data-screen-label="Ubicacion"
>
  <div class="location-container">
    <div class="location-grid">
      <div class="location-map reveal">
        <div class="map-frame">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.0!2d-75.3418145!3d6.1880394!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e46a10044cddb71%3A0x9db2b94ed46991da!2sLaguna%20Escondida!5e0!3m2!1ses!2sco!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={t.location.mapTitle}
          ></iframe>
        </div>
      </div>

      <div class="location-info reveal stagger-1">
        <SectionHeading
          eyebrow={t.location.eyebrow}
          title={t.location.heading}
          subtitle={t.location.subtitle}
        />

        <dl class="location-dl">
          <div>
            <dt>{t.location.fromMedellin}</dt>
            <dd set:html={t.location.fromMedellinDesc} />
          </div>
          <div>
            <dt>{t.location.fromRionegro}</dt>
            <dd set:html={t.location.fromRionegroDesc} />
          </div>
        </dl>

        <div class="hours-block">
          <p class="hours-label">{t.location.hours}</p>
          <dl class="hours-dl">
            <div>
              <dt>{t.location.hoursSatSun}</dt>
              <dd>{t.location.hoursSatSunTime}</dd>
            </div>
            <div>
              <dt>{t.location.hoursHolidays}</dt>
              <dd>{t.location.hoursHolidaysTime}</dd>
            </div>
            <div>
              <dt>{t.location.hoursWeekdays}</dt>
              <dd>{t.location.hoursWeekdaysTime}</dd>
            </div>
          </dl>
        </div>

        <div class="location-cta">
          <LinkRule
            href="https://maps.google.com/?q=Laguna+Escondida+Marinilla"
            label={t.location.openInMaps}
            event="maps_click"
            location="directions"
            target="_blank"
            rel="noopener"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location-section {
    padding-block: clamp(80px, 10vw, 160px);
    background: var(--color-surface-tint);
    border-top: 1px solid var(--color-line);
  }

  .location-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (min-width: 900px) {
    .location-grid {
      grid-template-columns: 5fr 6fr;
      gap: 96px;
    }
  }

  .location-map {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-olive-50);
  }

  .map-frame {
    position: absolute;
    inset: 0;
  }

  .map-frame iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  .location-info {
    display: grid;
    gap: 32px;
  }

  .location-dl {
    margin: 0;
    display: grid;
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid var(--color-line);
  }

  .location-dl > div {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    align-items: baseline;
  }

  @media (max-width: 639px) {
    .location-dl > div {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }

  .location-dl dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .location-dl dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: var(--color-ink);
  }

  .location-dl dd :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .hours-block {
    padding-top: 28px;
    border-top: 1px solid var(--color-line);
    display: grid;
    gap: 16px;
  }

  .hours-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .hours-dl {
    margin: 0;
    display: grid;
    gap: 8px;
  }

  .hours-dl > div {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    align-items: baseline;
  }

  @media (max-width: 639px) {
    .hours-dl > div {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }

  .hours-dl dt {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-ink);
    font-weight: 500;
  }

  .hours-dl dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-ink-muted);
  }

  .location-cta {
    margin-top: 8px;
  }
</style>
