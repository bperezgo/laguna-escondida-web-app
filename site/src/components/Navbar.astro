---
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);

const waHref = 'https://wa.me/573194313781?text=Hola%2C%20quiero%20reservar%20en%20Laguna%20Escondida';

const navLinks = [
  { href: '/#experiencias', label: t.navbar.experiences },
  { href: '/menu', label: t.navbar.menu },
  { href: '/#especies', label: t.navbar.fishing },
  { href: '/#galeria', label: t.navbar.gallery },
  { href: '/#resenas', label: t.navbar.reviews },
  { href: '/#ubicacion', label: t.navbar.directions },
];
---

<header class="site-header" id="site-header">
  <div class="bar">
    <div class="bar-slot bar-start">
      <nav aria-label="primary" class="nav-list">
        {navLinks.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
      <button id="mobile-menu-btn" class="menu-trigger" aria-label={t.navbar.openMenu}>
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <span>{t.navbar.menu}</span>
      </button>
    </div>

    <a href="/" class="brandmark" aria-label={t.navbar.brandName}>
      <img src="/logo-navbar.png" alt="" width="32" height="32" class="brandmark-logo" />
      <span class="brandmark-wordmark">{t.navbar.brandName}</span>
    </a>
  </div>
</header>

<div id="mobile-drawer-overlay" class="drawer-overlay" aria-hidden="true"></div>

<nav id="mobile-drawer" class="drawer" aria-label="mobile">
  <div class="drawer-header">
    <span class="drawer-brand">
      <img src="/logo-navbar.png" alt="" width="28" height="28" />
      <span>{t.navbar.brandName}</span>
    </span>
    <button id="mobile-drawer-close" class="drawer-close" aria-label={t.navbar.closeMenu}>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <ul class="drawer-nav">
    {navLinks.map((l) => (
      <li>
        <a href={l.href} class="mobile-drawer-link">{l.label}</a>
      </li>
    ))}
  </ul>

  <div class="drawer-cta">
    <a
      href={waHref}
      class="btn-editorial btn-editorial-primary drawer-cta-btn"
      data-event="whatsapp_click"
      data-location="navbar-mobile"
    >
      {t.navbar.reserve}
    </a>
  </div>
</nav>

<style>
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(250, 248, 243, 0.92);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid transparent;
    color: var(--color-ink);
    transition: border-color var(--duration-3) var(--ease-out), background var(--duration-3) var(--ease-out);
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--color-line);
    background: rgba(250, 248, 243, 0.96);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px var(--gutter);
    max-width: var(--container-width);
    margin: 0 auto;
  }

  .bar-slot {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-list {
    display: none;
    gap: 28px;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .nav-list a {
    position: relative;
    padding-bottom: 2px;
    color: inherit;
    text-decoration: none;
  }

  .nav-list a::after {
    content: "";
    position: absolute;
    left: 50%;
    right: 50%;
    bottom: -3px;
    height: 1px;
    background: var(--color-earth-300);
    transition: left var(--duration-2) var(--ease-out), right var(--duration-2) var(--ease-out);
  }

  .nav-list a:hover::after {
    left: 0;
    right: 0;
  }

  .menu-trigger {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    color: inherit;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 4px 0;
  }

  .menu-icon {
    width: 22px;
    height: 22px;
  }

  .brandmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-lake-700);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.02em;
  }

  .brandmark-logo {
    border-radius: 50%;
    display: block;
  }

  .brandmark-wordmark {
    display: none;
  }

  @media (min-width: 640px) {
    .brandmark-wordmark {
      display: inline;
    }
  }

  @media (min-width: 1024px) {
    .nav-list {
      display: flex;
    }
    .menu-trigger {
      display: none;
    }
  }

  /* ── Drawer ── */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(14, 32, 25, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-2) var(--ease-out);
    z-index: 100;
  }

  .drawer-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    height: 100%;
    width: 300px;
    max-width: 85vw;
    background: var(--color-lake-800);
    color: var(--color-sand-50);
    transform: translateX(100%);
    transition: transform var(--duration-3) var(--ease-out);
    z-index: 101;
    display: flex;
    flex-direction: column;
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  @media (min-width: 1024px) {
    .drawer-overlay,
    .drawer {
      display: none;
    }
  }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .drawer-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--color-sand-50);
  }

  .drawer-brand img {
    border-radius: 50%;
  }

  .drawer-close {
    background: none;
    border: 0;
    color: var(--color-sand-50);
    cursor: pointer;
    padding: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .drawer-close svg {
    width: 22px;
    height: 22px;
  }

  .drawer-nav {
    list-style: none;
    padding: 16px 24px;
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-drawer-link {
    display: block;
    padding: 12px 8px;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    color: rgba(250, 248, 243, 0.92);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background var(--duration-1) var(--ease-out), color var(--duration-1) var(--ease-out);
  }

  .mobile-drawer-link:hover {
    color: var(--color-earth-300);
    background: rgba(255, 255, 255, 0.04);
  }

  .drawer-cta {
    padding: 20px 24px 32px;
    border-top: 1px solid rgba(197, 169, 97, 0.35);
  }

  .drawer-cta-btn {
    width: 100%;
    justify-content: center;
    background: var(--color-sand-50);
    color: var(--color-lake-800);
    border-color: var(--color-sand-50);
  }

  .drawer-cta-btn:hover {
    background: #ffffff;
  }
</style>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    var btn = document.getElementById('mobile-menu-btn');
    var overlay = document.getElementById('mobile-drawer-overlay');
    var drawer = document.getElementById('mobile-drawer');
    var closeBtn = document.getElementById('mobile-drawer-close');

    function getWaBtn() {
      return document.getElementById('wa-floating-btn');
    }

    function open() {
      overlay.classList.add('is-open');
      drawer.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      var wa = getWaBtn();
      if (wa) wa.style.display = 'none';
    }

    function close() {
      overlay.classList.remove('is-open');
      drawer.classList.remove('is-open');
      document.body.style.overflow = '';
      var wa = getWaBtn();
      if (wa) wa.style.display = '';
    }

    if (btn) btn.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (overlay) overlay.addEventListener('click', close);

    var links = drawer ? drawer.querySelectorAll('.mobile-drawer-link') : [];
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', close);
    }

    function onScroll() {
      if (!header) return;
      if (window.scrollY > 24) header.classList.add('is-scrolled');
      else header.classList.remove('is-scrolled');
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
