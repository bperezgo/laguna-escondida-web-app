---
import { sanityClient, responsiveImage } from '../lib/sanity';
import { GALLERY_QUERY } from '../lib/queries/gallery';
import SectionHeading from './ui/SectionHeading.astro';
import FigureCaption from './ui/FigureCaption.astro';
import LinkRule from './ui/LinkRule.astro';
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);

type GalleryItem = {
  _id: string;
  image: { alt?: string };
  gridSize?: string;
  order?: number;
  caption?: string;
};

const galleryImages: GalleryItem[] = await sanityClient.fetch(GALLERY_QUERY);
const total = galleryImages.length;

const pad = (n: number) => String(n).padStart(2, '0');
---

<section
  class="gallery-section"
  id="galeria"
  data-section="galeria"
  data-screen-label="Galeria"
>
  <div class="gallery-container">
    <SectionHeading
      eyebrow={t.gallery.eyebrow}
      title={t.gallery.heading}
      subtitle={t.gallery.subtitle}
      class="reveal"
    />

    <div class="gallery-grid reveal stagger-1">
      {galleryImages.map((item, i) => {
        const slot = (i % 5) + 1;
        const imgAttrs = responsiveImage(
          item.image,
          slot === 1 ? [400, 800, 1200, 1600] : [400, 800, 1200],
          slot === 1 ? '(max-width: 720px) 100vw, 58vw' : '(max-width: 720px) 100vw, 33vw',
        );
        const alt = item.image?.alt || item.caption || '';
        return (
          <figure class={`gal gal-${slot}`}>
            <div class="media">
              <img
                src={imgAttrs.src}
                srcset={imgAttrs.srcset}
                sizes={imgAttrs.sizes}
                alt={alt}
                loading="lazy"
              />
            </div>
            <FigureCaption
              index={`${pad(i + 1)} / ${pad(total)}`}
              label={item.caption || ''}
            />
          </figure>
        );
      })}
    </div>

    <div class="gallery-cta reveal stagger-2">
      <LinkRule
        href="/galeria/"
        label={t.gallery.cta}
        event="galeria_cta_click"
        location="galeria"
      />
    </div>
  </div>
</section>

<style>
  .gallery-section {
    padding-block: clamp(80px, 10vw, 160px);
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
  }

  .gallery-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .gallery-grid {
    margin-top: 72px;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .gal {
    margin: 0;
    grid-column: span 12;
  }

  @media (min-width: 720px) {
    .gal-1 { grid-column: span 7; }
    .gal-2 { grid-column: span 5; }
    .gal-3 { grid-column: span 4; }
    .gal-4 { grid-column: span 4; }
    .gal-5 { grid-column: span 4; }
  }

  .media {
    width: 100%;
    overflow: hidden;
    background: var(--color-lake-700);
  }

  .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-4) var(--ease-out);
  }

  .gal:hover .media img {
    transform: scale(1.02);
  }

  .gal-1 .media { aspect-ratio: 16 / 10; }
  .gal-2 .media {
    aspect-ratio: 4 / 5;
    border-radius: 240px 240px 8px 8px;
  }
  .gal-3 .media {
    aspect-ratio: 1 / 1;
    border-radius: 999px 999px 8px 8px;
  }
  .gal-4 .media { aspect-ratio: 1 / 1; }
  .gal-5 .media {
    aspect-ratio: 1 / 1;
    border-radius: 50%;
  }

  .gallery-cta {
    margin-top: 64px;
    text-align: center;
  }
</style>
