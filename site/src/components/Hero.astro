---
import StarRating from './StarRating.astro';
import Eyebrow from './ui/Eyebrow.astro';
import Button from './ui/Button.astro';
import { sanityClient, responsiveImage } from '../lib/sanity';
import { HERO_SECTION_QUERY, type HeroSectionData } from '../lib/queries/heroSection';
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);

const hero = await sanityClient.fetch<HeroSectionData | null>(HERO_SECTION_QUERY);

const heroImg = hero?.backgroundImage
  ? responsiveImage(hero.backgroundImage, [640, 1024, 1600, 1920], '100vw')
  : { src: '/images/hero/lago-comedor-vista.jpg', srcset: '', sizes: '' };
const bgAlt = hero?.backgroundImage?.alt || t.hero.bgAlt;

const eyebrow = t.hero.eyebrow;
const line1 = hero?.headline?.line1 || t.hero.line1;
const line2 = hero?.headline?.line2 || t.hero.line2;
const line3 = hero?.headline?.line3 || t.hero.line3;
const subheadline = hero?.subheadline || t.hero.subheadline;

const waNumber = hero?.whatsappNumber || '57XXXXXXXXXX';
const waMessage = hero?.whatsappMessage || t.hero.waMessage;
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

const ctaPrimary = hero?.ctaPrimaryText || t.hero.ctaPrimary;
const ctaSecondary = hero?.ctaSecondaryText || t.hero.ctaSecondary;
const trustBadge = hero?.trustBadgeText || t.hero.trustBadge;

const stats = hero?.stats && hero.stats.length > 0 ? hero.stats : t.hero.stats;
const houseNoteEyebrow = hero?.houseNoteEyebrow || t.hero.houseNoteEyebrow;
const houseNote = hero?.houseNote || t.hero.houseNote;
const scrollHint = t.hero.scrollHint;
---
<section class="hero" id="inicio" data-section="hero" data-screen-label="Hero">
  <div class="hero-bg">
    <img
      src={heroImg.src}
      srcset={heroImg.srcset}
      sizes={heroImg.sizes}
      alt={bgAlt}
      class="hero-img"
      loading="eager"
      fetchpriority="high"
      data-parallax
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-grid">
      <div class="hero-content">
        <Eyebrow text={eyebrow} inverse />
        <h1 class="hero-title">
          {line1}<br />
          {line2}<br />
          <em>{line3}</em>
        </h1>
        <p class="hero-lead">{subheadline}</p>

        <div class="hero-actions">
          <Button
            variant="inverse-primary"
            href={waHref}
            event="whatsapp_click"
            location="hero"
            withDot
          >
            {ctaPrimary}
          </Button>
          <Button variant="inverse-secondary" href="#experiencias">
            {ctaSecondary}
          </Button>
        </div>

        <div class="hero-meta">
          {stats.map((s) => (
            <div class="cell">
              <div class="caption">{s.label}</div>
              <div class="val">{s.value}</div>
            </div>
          ))}
        </div>

        <div class="hero-trust">
          <StarRating />
          <span>{trustBadge}</span>
        </div>
      </div>
    </div>

    <aside class="hero-side">
      <div class="card-note">
        <Eyebrow text={houseNoteEyebrow} inverse />
        <p>{houseNote}</p>
      </div>
    </aside>

    <div class="scroll-hint" aria-hidden="true">
      <span class="line"></span>
      <span>{scrollHint}</span>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var img = document.querySelector('[data-parallax]');
    if (!img || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var ticking = false;
    window.addEventListener(
      'scroll',
      function () {
        if (!ticking) {
          requestAnimationFrame(function () {
            img.style.transform = 'translateY(' + window.scrollY * -0.15 + 'px)';
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding-top: 120px;
    padding-bottom: 80px;
    overflow: hidden;
    color: var(--color-sand-50);
    background: var(--color-lake-800);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    will-change: transform;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(7, 19, 14, 0) 0%,
      rgba(7, 19, 14, 0.1) 35%,
      rgba(7, 19, 14, 0.65) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    min-height: calc(100vh - 200px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: end;
    min-height: calc(100vh - 200px);
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.4fr 1fr;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    margin-top: 24px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.75rem, 7vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: var(--color-sand-50);
    max-width: 16ch;
  }

  .hero-title em {
    font-style: italic;
    color: var(--color-earth-300);
    font-weight: 300;
  }

  .hero-lead {
    margin-top: 24px;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.78);
    max-width: 48ch;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 32px;
    margin-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    max-width: 720px;
    width: 100%;
  }

  .hero-meta .cell .caption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(236, 242, 240, 0.55);
  }

  .hero-meta .cell .val {
    margin-top: 6px;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    color: var(--color-sand-50);
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: rgba(250, 248, 243, 0.75);
  }

  .hero-side {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero-side {
      display: block;
      position: absolute;
      right: var(--gutter);
      bottom: 96px;
      width: 280px;
      z-index: 3;
    }
  }

  .card-note {
    background: rgba(250, 248, 243, 0.06);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 24px;
    border-radius: var(--radius-md);
  }

  .card-note p {
    margin: 14px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: rgba(250, 248, 243, 0.9);
    line-height: 1.55;
    font-size: var(--text-body);
  }

  .scroll-hint {
    position: absolute;
    right: var(--gutter);
    bottom: 24px;
    z-index: 3;
    display: none;
    align-items: center;
    gap: 14px;
    color: rgba(250, 248, 243, 0.6);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (min-width: 1280px) {
    .scroll-hint {
      display: flex;
    }
  }

  .scroll-hint .line {
    width: 60px;
    height: 1px;
    background: rgba(250, 248, 243, 0.4);
    position: relative;
    overflow: hidden;
  }

  .scroll-hint .line::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-earth-300);
    transform: translateX(-100%);
    animation: scrollHint 3.2s var(--ease-in-out) infinite;
  }

  @keyframes scrollHint {
    0% {
      transform: translateX(-100%);
    }
    55% {
      transform: translateX(100%);
    }
    100% {
      transform: translateX(100%);
    }
  }
</style>
