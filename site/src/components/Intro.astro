---
import Eyebrow from './ui/Eyebrow.astro';
import { sanityClient } from '../lib/sanity';
import { INTRO_SECTION_QUERY, type IntroSectionData } from '../lib/queries/introSection';
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);

const intro = await sanityClient.fetch<IntroSectionData | null>(INTRO_SECTION_QUERY);

const eyebrow = intro?.eyebrow || t.intro.eyebrow;
const heading = intro?.heading || t.intro.heading;
const lead = intro?.lead || t.intro.lead;
const body = intro?.body || t.intro.body;
const stats = intro?.stats && intro.stats.length > 0 ? intro.stats : t.intro.stats;
---

<section
  class="intro-section"
  data-section="intro"
  data-screen-label="Intro"
>
  <div class="intro-container">
    <div class="intro-grid">
      <div class="intro-lead-col reveal">
        <Eyebrow text={eyebrow} />
        <h2 class="intro-heading">{heading}</h2>
      </div>
      <div class="intro-body-col reveal stagger-1">
        <p class="intro-lead">{lead}</p>
        <p class="intro-body">{body}</p>
        <dl class="intro-stats">
          {stats.map((s) => (
            <div class="stat">
              <dt class="stat-value">{s.value}</dt>
              <dd class="stat-label">{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-section {
    padding-block: clamp(80px, 10vw, 160px);
    background: var(--color-surface-tint);
    border-top: 1px solid var(--color-line);
  }

  .intro-container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
  }

  @media (min-width: 900px) {
    .intro-grid {
      grid-template-columns: 5fr 6fr;
      gap: 96px;
      align-items: start;
    }
  }

  .intro-heading {
    margin: 16px 0 0;
    max-width: 16ch;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4.4vw, 3.375rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .intro-lead {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    color: var(--color-ink);
  }

  .intro-body {
    margin: 24px 0 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  .intro-stats {
    margin: 48px 0 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid var(--color-line);
  }

  .stat {
    margin: 0;
  }

  .stat-value {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    line-height: 1;
    color: var(--color-lake-700);
  }

  .stat-label {
    margin: 8px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
</style>
