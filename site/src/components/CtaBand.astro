---
import Eyebrow from './ui/Eyebrow.astro';
import Button from './ui/Button.astro';
import { sanityClient } from '../lib/sanity';
import { CTA_BAND_SECTION_QUERY, type CtaBandSectionData } from '../lib/queries/ctaBandSection';
import { HERO_SECTION_QUERY, type HeroSectionData } from '../lib/queries/heroSection';
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'es') as Locale;
const t = useTranslations(locale);

const [ctaBand, hero] = await Promise.all([
  sanityClient.fetch<CtaBandSectionData | null>(CTA_BAND_SECTION_QUERY),
  sanityClient.fetch<HeroSectionData | null>(HERO_SECTION_QUERY),
]);

const eyebrow = ctaBand?.eyebrow || t.ctaBand.eyebrow;
const heading = ctaBand?.heading || t.ctaBand.heading;
const primaryCta = ctaBand?.primaryCtaText || hero?.ctaPrimaryText || t.hero.ctaPrimary;
const whatsappCta = ctaBand?.whatsappCtaText || t.ctaBand.whatsappCta;

const waNumber = ctaBand?.whatsappNumber || hero?.whatsappNumber || '573194313781';
const waMessage = ctaBand?.whatsappMessage || hero?.whatsappMessage || t.hero.waMessage;
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;
---

<section
  class="cta-band"
  id="reservar"
  data-section="reservar"
  data-screen-label="CTA reservar"
>
  <div class="cta-container">
    <div class="cta-text reveal">
      <Eyebrow text={eyebrow} inverse />
      <h2 class="cta-heading">{heading}</h2>
    </div>
    <div class="cta-actions reveal stagger-1">
      <Button
        variant="inverse-primary"
        href={waHref}
        event="reservation_cta_click"
        location="cta_band"
        target="_blank"
        rel="noopener"
      >
        {primaryCta}
        <span class="arrow" aria-hidden="true">→</span>
      </Button>
      <Button
        variant="whatsapp"
        href={waHref}
        event="whatsapp_click"
        location="cta_band"
        target="_blank"
        rel="noopener"
        withDot
      >
        {whatsappCta}
      </Button>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    overflow: hidden;
    padding-block: clamp(80px, 10vw, 140px);
    background: var(--color-lake-800);
    color: var(--color-sand-50);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .cta-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px 300px at 80% 50%,
      rgba(197, 169, 97, 0.1),
      transparent 60%
    );
    pointer-events: none;
  }

  .cta-container {
    position: relative;
    max-width: var(--container-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: end;
  }

  @media (min-width: 900px) {
    .cta-container {
      grid-template-columns: 1.5fr 1fr;
      gap: 64px;
    }
  }

  .cta-heading {
    margin: 16px 0 0;
    max-width: 22ch;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-sand-50);
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  @media (min-width: 900px) {
    .cta-actions {
      align-items: flex-end;
    }
  }

  .cta-actions :global(.btn-editorial) {
    min-width: 240px;
    justify-content: center;
  }

  .cta-actions :global(.arrow) {
    margin-left: 8px;
  }
</style>
