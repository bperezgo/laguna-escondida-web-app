---
// src/components/molecules/Card.astro

import Badge from '@/components/atoms/Badge.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  href?: string;
  badge?: string;
  class?: string;
  horizontal?: boolean;
}

const {
  title,
  description,
  image,
  imageAlt = title,
  href,
  badge,
  class: className = '',
  horizontal = false,
} = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class={[
    'group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-250',
    horizontal ? 'flex flex-col sm:flex-row' : 'flex flex-col',
    href ? 'cursor-pointer' : '',
    className,
  ].join(' ')}
>
  {image && (
    <div class={[
      'overflow-hidden',
      horizontal ? 'sm:w-2/5 flex-shrink-0' : 'aspect-video',
    ].join(' ')}>
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  )}

  <div class="flex flex-col gap-3 p-5 flex-1">
    {badge && (
      <div>
        <Badge variant="primary" size="sm">{badge}</Badge>
      </div>
    )}

    <h3 class="font-heading text-xl font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">
      {title}
    </h3>

    {description && (
      <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
    )}

    <slot />
  </div>
</Tag>
