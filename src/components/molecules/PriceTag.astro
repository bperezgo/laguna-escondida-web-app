---
// src/components/molecules/PriceTag.astro

import { formatPrice } from '@/lib/utils/formatters';

export interface Props {
  amount: number;
  currency?: string;
  period?: string;
  prefix?: string;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const {
  amount,
  currency = 'COP',
  period,
  prefix = 'Desde',
  class: className = '',
  size = 'md',
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'text-xl',
  md: 'text-3xl',
  lg: 'text-5xl',
};
---

<div class={`flex flex-col ${className}`}>
  {prefix && <span class="text-xs text-gray-500 uppercase tracking-wider">{prefix}</span>}
  <div class="flex items-baseline gap-1">
    <span class={`font-heading font-bold text-primary-600 ${sizeClasses[size]}`}>
      {formatPrice(amount, currency)}
    </span>
    {period && <span class="text-sm text-gray-500">/ {period}</span>}
  </div>
</div>
