---
// src/components/widgets/Analytics/CustomTracker.astro
// Exposes window.trackEvent for inline client-side code.
---

<script>
  import { trackEvent } from '@/lib/usecases/analytics/trackEvent';
  import { trackPageView } from '@/lib/usecases/analytics/trackPageView';

  // Expose globally for inline scripts and Astro component <script> blocks
  window.trackEvent = trackEvent;
  window.trackPageView = trackPageView;

  // Auto page-view tracking on initial load
  trackPageView({
    path: window.location.pathname,
    title: document.title,
    referrer: document.referrer,
  });
</script>
