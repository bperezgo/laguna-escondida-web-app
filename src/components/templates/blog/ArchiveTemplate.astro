---
// src/components/templates/blog/ArchiveTemplate.astro

import BlogPostList from '@/components/organisms/BlogPostList.astro';
import Badge from '@/components/atoms/Badge.astro';
import { BLOG_CATEGORIES } from '@/lib/utils/constants';
import type { BlogPost } from '@/types/blog';

export interface Props {
  posts: BlogPost[];
  title: string;
  description?: string;
  activeCategory?: string;
}

const { posts, title, description, activeCategory } = Astro.props;
---

<section class="section">
  <div class="container">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="font-heading text-4xl md:text-5xl text-gray-800 mb-4">{title}</h1>
      {description && <p class="text-lg text-gray-600 max-w-2xl mx-auto">{description}</p>}
    </div>

    <!-- Category filter -->
    <nav aria-label="Categorías del blog" class="flex flex-wrap gap-2 justify-center mb-10">
      <a
        href="/contenido"
        class={[
          'px-4 py-2 rounded-full text-sm font-medium transition-all',
          !activeCategory
            ? 'bg-primary-500 text-white'
            : 'bg-neutral-100 text-neutral-700 hover:bg-primary-100 hover:text-primary-700',
        ].join(' ')}
      >
        Todos
      </a>
      {BLOG_CATEGORIES.map((cat) => (
        <a
          href={`/contenido/categoria/${cat.slug}`}
          class={[
            'px-4 py-2 rounded-full text-sm font-medium transition-all',
            activeCategory === cat.slug
              ? 'bg-primary-500 text-white'
              : 'bg-neutral-100 text-neutral-700 hover:bg-primary-100 hover:text-primary-700',
          ].join(' ')}
        >
          {cat.label}
        </a>
      ))}
    </nav>

    <!-- Posts grid -->
    <BlogPostList posts={posts} />
  </div>
</section>
