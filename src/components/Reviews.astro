---
import reviewsData from '../data/reviews.json';
import StarRating from './StarRating.astro';
---

<section class="section-padding bg-lake-50" id="resenas">
  <div class="section-container">
    <h2 class="section-heading">
      Que dicen quienes nos han visitado?
    </h2>

    <!-- Rating badge -->
    <div class="flex items-center justify-center gap-3 mb-8 sm:mb-12">
      <StarRating size="lg" />
      <span class="text-2xl font-bold text-lake-700 font-body">4.6</span>
      <a href="https://g.page/r/XXXX/review"
         class="text-lake-500 underline font-body"
         target="_blank" rel="noopener"
         data-event="maps_click" data-location="reviews">
        Ver en Google Maps
      </a>
    </div>

    <!-- Testimonios -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviewsData.map((review) => (
        <div class="card-standard">
          <StarRating count={review.stars} size="sm" class="mb-3" />
          <p class="font-body text-neutral italic mb-4">"{review.text}"</p>
          <p class="font-body text-sm text-lake-700 font-semibold">— {review.author}</p>
        </div>
      ))}
    </div>

    <!-- CTA dejar resena -->
    <div class="text-center mt-10">
      <a href="https://g.page/r/XXXX/review"
         class="section-cta"
         target="_blank" rel="noopener"
         data-event="maps_click" data-location="leave-review">
        Dejar una resena en Google &rarr;
      </a>
    </div>
  </div>
</section>
