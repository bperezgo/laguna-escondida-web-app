---
// src/components/organisms/BlogPostList.astro

import Card from '@/components/molecules/Card.astro';
import Badge from '@/components/atoms/Badge.astro';
import { formatDate } from '@/lib/utils/formatters';
import type { BlogPost } from '@/types/blog';

export interface Props {
  posts: BlogPost[];
  class?: string;
  columns?: 2 | 3;
}

const { posts, class: className = '', columns = 3 } = Astro.props;

const gridClass = columns === 2
  ? 'grid-cols-1 md:grid-cols-2'
  : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
---

{posts.length === 0 ? (
  <div class="text-center py-16 text-gray-500">
    <p class="text-lg">No hay publicaciones en esta categoría todavía.</p>
    <p class="text-sm mt-2">Vuelve pronto para nuevo contenido.</p>
  </div>
) : (
  <div class={`grid ${gridClass} gap-6 ${className}`}>
    {posts.map((post) => (
      <article>
        <Card
          title={post.title}
          description={post.excerpt}
          image={post.coverImage}
          imageAlt={post.title}
          href={`/contenido/${post.slug}`}
          badge={post.category.name}
        >
          <div class="flex items-center justify-between mt-auto pt-3 border-t border-neutral-100 text-xs text-gray-500">
            <span>{formatDate(post.publishedAt, { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            {post.readingTime && <span>{post.readingTime} min de lectura</span>}
          </div>
        </Card>
      </article>
    ))}
  </div>
)}
