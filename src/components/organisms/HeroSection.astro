---
// src/components/organisms/HeroSection.astro

import Button from '@/components/atoms/Button.astro';

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  primaryCta?: { label: string; href: string; analyticsEvent?: string };
  secondaryCta?: { label: string; href: string };
  backgroundImage?: string;
  backgroundVideo?: string;
  overlay?: boolean;
  class?: string;
  size?: 'sm' | 'md' | 'lg' | 'full';
}

const {
  title,
  subtitle,
  description,
  primaryCta,
  secondaryCta,
  backgroundImage,
  backgroundVideo,
  overlay = true,
  class: className = '',
  size = 'lg',
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'min-h-[40vh]',
  md: 'min-h-[60vh]',
  lg: 'min-h-[80vh]',
  full: 'min-h-screen',
};
---

<section
  class={[
    'relative flex items-center justify-center overflow-hidden',
    sizeClasses[size],
    className,
  ].join(' ')}
>
  <!-- Background media -->
  {backgroundVideo ? (
    <video
      class="absolute inset-0 w-full h-full object-cover"
      src={backgroundVideo}
      autoplay
      muted
      loop
      playsinline
    />
  ) : backgroundImage ? (
    <img
      src={backgroundImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-primary-800 via-primary-700 to-secondary-800" />
  )}

  <!-- Overlay -->
  {overlay && (
    <div class="absolute inset-0 bg-black/40" />
  )}

  <!-- Content -->
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
    {subtitle && (
      <p class="text-overline text-accent-300 mb-4 animate-fade-in-down">{subtitle}</p>
    )}

    <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-6 animate-fade-in-up leading-tight">
      {title}
    </h1>

    {description && (
      <p class="text-lg md:text-xl text-white/80 mb-10 max-w-2xl mx-auto animate-fade-in delay-200">
        {description}
      </p>
    )}

    {(primaryCta || secondaryCta) && (
      <div class="flex flex-wrap items-center justify-center gap-4 animate-fade-in-up delay-300">
        {primaryCta && (
          <Button
            href={primaryCta.href}
            variant="accent"
            size="lg"
            data-analytics-event={primaryCta.analyticsEvent}
          >
            {primaryCta.label}
          </Button>
        )}
        {secondaryCta && (
          <Button href={secondaryCta.href} variant="outline" size="lg" class="border-white text-white hover:bg-white/10">
            {secondaryCta.label}
          </Button>
        )}
      </div>
    )}

    <slot />
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-pulse">
    <svg class="w-6 h-8 text-white/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
