---
// src/components/organisms/GalleryGrid.astro

export interface GalleryImage {
  src: string;
  alt: string;
  category: string;
  width?: number;
  height?: number;
}

export interface Props {
  images: GalleryImage[];
  categories?: string[];
  class?: string;
}

const { images, categories = [], class: className = '' } = Astro.props;

// Build unique category list if not provided
const allCategories = categories.length > 0
  ? categories
  : [...new Set(images.map((img) => img.category))];
---

<div class={className}>
  <!-- Category filter tabs -->
  {allCategories.length > 1 && (
    <div class="flex flex-wrap gap-2 mb-8" id="gallery-filters" role="tablist">
      <button
        class="gallery-filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all"
        data-filter="all"
        role="tab"
        aria-selected="true"
      >
        Todos
      </button>
      {allCategories.map((cat) => (
        <button
          class="gallery-filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all"
          data-filter={cat}
          role="tab"
          aria-selected="false"
        >
          {cat}
        </button>
      ))}
    </div>
  )}

  <!-- Grid -->
  <div
    id="gallery-grid"
    class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3"
  >
    {images.map((img) => (
      <div
        class="gallery-item break-inside-avoid rounded-xl overflow-hidden cursor-pointer group"
        data-category={img.category}
      >
        <img
          src={img.src}
          alt={img.alt}
          loading="lazy"
          class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    ))}
  </div>

  <!-- Empty state -->
  <p id="gallery-empty" class="hidden text-center text-gray-500 py-16">
    No hay imágenes en esta categoría todavía.
  </p>
</div>

<style>
  .gallery-filter-btn {
    background-color: var(--color-neutral-100);
    color: var(--color-neutral-700);
  }
  .gallery-filter-btn:hover {
    background-color: var(--color-primary-100);
    color: var(--color-primary-700);
  }
  .gallery-filter-btn.active {
    background-color: var(--color-primary-500);
    color: white;
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.gallery-filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');
  const emptyState = document.getElementById('gallery-empty')!;

  function applyFilter(filter: string) {
    let visible = 0;
    items.forEach((item) => {
      const show = filter === 'all' || item.dataset.category === filter;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    emptyState.classList.toggle('hidden', visible > 0);

    // Update aria-selected
    filterBtns.forEach((btn) => {
      const isActive = btn.dataset.filter === filter;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', String(isActive));
    });

    // Track analytics
    if (filter !== 'all' && window.trackEvent) {
      window.trackEvent('gallery_filter_changed', { category: filter });
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.filter ?? 'all');
    });
  });
</script>
