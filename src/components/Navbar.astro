---
---
<div class="navbar bg-sand-100 sticky top-0 z-50 shadow-brand border-b border-lake-50">
  <div class="navbar-start">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo-navbar.png" alt="Laguna Escondida" width="40" height="40" class="rounded-full" />
      <span class="text-2xl font-display text-lake-700 tracking-tight hidden sm:inline">Laguna Escondida</span>
    </a>
  </div>
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 font-body text-lake-700">
      <li><a href="#experiencias">Experiencias</a></li>
      <li><a href="#especies">Pesca</a></li>
      <li><a href="#galeria">Galeria</a></li>
      <li><a href="#resenas">Resenas</a></li>
      <li><a href="#ubicacion">Como llegar</a></li>
    </ul>
  </div>
  <div class="navbar-end gap-2">
    <a href="https://wa.me/573194313781?text=Hola%2C%20quiero%20reservar%20en%20Laguna%20Escondida"
       class="btn btn-primary text-white hidden sm:inline-flex"
       data-event="whatsapp_click" data-location="navbar">
      Reservar visita
    </a>
    <!-- Mobile menu trigger -->
    <button id="mobile-menu-btn" class="btn btn-ghost lg:hidden" aria-label="Abrir menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Mobile drawer overlay -->
    <div id="mobile-drawer-overlay" class="fixed inset-0 bg-lake-700/60 backdrop-blur-sm z-100 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

    <!-- Mobile drawer -->
    <nav id="mobile-drawer" class="fixed top-0 right-0 h-full w-72 bg-lake-700 z-101 translate-x-full transition-transform duration-300 ease-out lg:hidden flex flex-col">
      <!-- Drawer header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-lake-500/40">
        <span class="font-display text-lg text-white tracking-tight">Laguna Escondida</span>
        <button id="mobile-drawer-close" class="btn btn-ghost btn-sm text-white hover:bg-white/10" aria-label="Cerrar menú">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Nav links -->
      <ul class="flex flex-col px-6 py-6 gap-1 flex-1">
        <li><a href="#experiencias" class="mobile-drawer-link block py-3 px-2 font-display text-lg text-white/90 hover:text-earth-300 rounded-lg hover:bg-white/5 transition-colors">Experiencias</a></li>
        <li><a href="#especies" class="mobile-drawer-link block py-3 px-2 font-display text-lg text-white/90 hover:text-earth-300 rounded-lg hover:bg-white/5 transition-colors">Pesca</a></li>
        <li><a href="#galeria" class="mobile-drawer-link block py-3 px-2 font-display text-lg text-white/90 hover:text-earth-300 rounded-lg hover:bg-white/5 transition-colors">Galeria</a></li>
        <li><a href="#resenas" class="mobile-drawer-link block py-3 px-2 font-display text-lg text-white/90 hover:text-earth-300 rounded-lg hover:bg-white/5 transition-colors">Reseñas</a></li>
        <li><a href="#ubicacion" class="mobile-drawer-link block py-3 px-2 font-display text-lg text-white/90 hover:text-earth-300 rounded-lg hover:bg-white/5 transition-colors">Cómo llegar</a></li>
      </ul>

      <!-- CTA -->
      <div class="px-6 pb-8">
        <div class="border-t border-earth-300/40 pt-6">
          <a href="https://wa.me/57XXXXXXXXXX?text=Hola%2C%20quiero%20reservar%20en%20Laguna%20Escondida"
             class="btn w-full bg-earth-300 hover:bg-earth-500 text-lake-700 border-0 font-body font-semibold text-base"
             data-event="whatsapp_click" data-location="navbar-mobile">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Reservar visita
          </a>
        </div>
      </div>
    </nav>
  </div>
</div>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobile-menu-btn');
    var overlay = document.getElementById('mobile-drawer-overlay');
    var drawer = document.getElementById('mobile-drawer');
    var closeBtn = document.getElementById('mobile-drawer-close');

    function getWaBtn() {
      return document.getElementById('wa-floating-btn');
    }

    function open() {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      drawer.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden';
      var wa = getWaBtn();
      if (wa) wa.style.display = 'none';
    }

    function close() {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      drawer.classList.add('translate-x-full');
      document.body.style.overflow = '';
      var wa = getWaBtn();
      if (wa) wa.style.display = '';
    }

    btn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    var links = drawer.querySelectorAll('.mobile-drawer-link');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', close);
    }
  })();
</script>
