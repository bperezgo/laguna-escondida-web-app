---
import { sanityClient, responsiveImage } from '../lib/sanity';
import { BLOG_PREVIEW_QUERY } from '../lib/queries/blog';

const posts = await sanityClient.fetch(BLOG_PREVIEW_QUERY);
---

<section class="section-padding bg-lake-50" id="blog">
  <div class="section-container">
    <h2 class="section-heading">
      Aprende sobre pesca y gastronomia campestre
    </h2>
    <p class="section-subtitle">
      Guias de pesca, recetas con pescado fresco y planes para hacer en el Oriente Antioqueno.
    </p>

    {posts.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post: any) => (
          <a href={`/contenido/${post.slug.current}`} class="card-hoverable group">
            <figure>
              {(() => {
                const imgAttrs = responsiveImage(
                  post.featuredImage,
                  [400, 800],
                  '(max-width: 640px) 100vw, 33vw',
                );
                return (
                  <img
                    src={imgAttrs.src}
                    srcset={imgAttrs.srcset}
                    sizes={imgAttrs.sizes}
                    alt={post.featuredImage?.alt || post.title}
                    class="w-full h-48 object-cover rounded-t-brand"
                    loading="lazy"
                  />
                );
              })()}
            </figure>
            <div class="card-body">
              <div class={`badge badge-${post.category?.badgeClass || 'primary'} badge-outline font-body`}>{post.category?.title}</div>
              <h3 class="card-title font-display text-lg text-lake-700 group-hover:text-lake-500 transition-colors duration-300">{post.title}</h3>
              <p class="font-body text-neutral text-sm">{post.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="text-center mt-10">
      <a href="/contenido/" class="section-cta">
        Ver todo el blog &rarr;
      </a>
    </div>
  </div>
</section>
