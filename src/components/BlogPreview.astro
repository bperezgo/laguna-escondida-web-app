---
import { sanityClient, urlFor } from '../lib/sanity';
import { BLOG_PREVIEW_QUERY } from '../lib/queries/blog';

const posts = await sanityClient.fetch(BLOG_PREVIEW_QUERY);
---

<section class="py-20 px-4 bg-lake-50" id="blog">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-display text-3xl md:text-4xl text-lake-700 text-center mb-4">
      Aprende sobre pesca y gastronomia campestre
    </h2>
    <p class="text-center text-lg text-neutral mb-12 max-w-2xl mx-auto font-body">
      Guias de pesca, recetas con pescado fresco y planes para hacer en el Oriente Antioqueno.
    </p>

    {posts.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post: any) => (
          <a href={`/contenido/${post.slug.current}`} class="card bg-white shadow-brand hover:shadow-brand-lg transition-all duration-300 hover:-translate-y-1">
            <figure>
              <img
                src={urlFor(post.featuredImage).width(400).height(200).url()}
                alt={post.featuredImage?.alt || post.title}
                class="w-full h-48 object-cover rounded-t-brand"
                loading="lazy"
              />
            </figure>
            <div class="card-body">
              <div class={`badge badge-${post.category?.badgeClass || 'primary'} badge-outline font-body`}>{post.category?.title}</div>
              <h3 class="card-title font-display text-lg text-lake-700">{post.title}</h3>
              <p class="font-body text-neutral text-sm">{post.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="text-center mt-10">
      <a href="/contenido/" class="btn btn-outline btn-primary font-body font-semibold">
        Ver todo el blog &rarr;
      </a>
    </div>
  </div>
</section>
