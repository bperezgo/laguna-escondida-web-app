---
// src/components/atoms/Image.astro

export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  class?: string;
  aspectRatio?: '1/1' | '4/3' | '16/9' | '3/2' | '21/9';
  objectFit?: 'cover' | 'contain' | 'fill' | 'none';
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  class: className = '',
  aspectRatio,
  objectFit = 'cover',
} = Astro.props;

const wrapperStyle = aspectRatio ? `aspect-ratio: ${aspectRatio};` : '';
const imgStyle = `object-fit: ${objectFit};`;
---

{aspectRatio ? (
  <div class={`overflow-hidden ${className}`} style={wrapperStyle}>
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      class="w-full h-full"
      style={imgStyle}
    />
  </div>
) : (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    class={className}
    style={imgStyle}
  />
)}
