---
const experiences = [
  {
    title: 'Pescar',
    description: 'Lago con 5 especies de peces: Yamu, Doradas, Cachama, Tilapia Roja y Tilapia Nilotica. La mayor variedad del Oriente Antioqueno.',
    href: '/experiencias/pesca-deportiva/',
    cta: 'Conocer mas',
    icon: `<path d="M6.5 12c3-6 10-6 14-2-4 4-11 4-14-2z M6.5 12c3 6 10 6 14 2 M3 12h3.5 M16 10l1-4 M16 14l1 4"/>`,
  },
  {
    title: 'Comer',
    description: 'Restaurante campestre con vista al lago. Yamu frito, Tilapia, Trucha y mas. Construccion en guadua, ambiente rustico autentico.',
    href: '/experiencias/restaurante/',
    cta: 'Ver menu',
    icon: `<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2 M7 2v20 M21 15V2v0a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>`,
  },
  {
    title: 'Celebrar',
    description: 'Cumpleanos, revelaciones de genero y reuniones con kiosco privado. Espacio campestre para hasta 60 personas frente al lago.',
    href: '/experiencias/eventos/',
    cta: 'Cotizar evento',
    icon: `<path d="M5.8 11.3L2 22l10.7-3.79 M4 3h.01 M22 8h.01 M15 2h.01 M22 20h.01 M22 2l-2.24.75a2.9 2.9 0 00-1.96 3.12v0c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/>`,
  },
];
---

<section class="section-padding bg-sand-100" id="experiencias">
  <div class="section-container">
    <h2 class="section-heading reveal">
      Que puedes hacer en Laguna Escondida?
    </h2>
    <p class="section-subtitle reveal stagger-1">
      Laguna Escondida es un restaurante campestre con lago de pesca deportiva ubicado en la Vereda La Primavera de Marinilla. Ofrece tres experiencias en un solo destino: pescar, comer y celebrar.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal stagger-2">
      {experiences.map((exp) => (
        <a href={exp.href} class="card-hoverable group">
          <figure class="px-6 pt-6">
            <div class="w-16 h-16 bg-lake-50 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-lake-500 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <Fragment set:html={exp.icon} />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h3 class="card-title font-display text-2xl text-lake-700">{exp.title}</h3>
            <p class="font-body text-neutral">{exp.description}</p>
            <div class="card-actions mt-4">
              <span class="text-lake-500 font-semibold font-body group-hover:translate-x-1 transition-transform duration-300">{exp.cta} &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
