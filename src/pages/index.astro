---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ExperienceCards from '../components/ExperienceCards.astro';
import FishSpecies from '../components/FishSpecies.astro';
import QuickGallery from '../components/QuickGallery.astro';
import Reviews from '../components/Reviews.astro';
import LocationMap from '../components/LocationMap.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Laguna Escondida — Pesca Deportiva y Restaurante Campestre en Marinilla, Antioquia"
  description="Pesca 5 especies de peces y come frente al lago. Restaurante campestre con Yamu, Doradas, Cachama, Tilapia Roja y Nilotica en Marinilla. A 45 min de Medellin."
>
  <Navbar />
  <main>
    <Hero />
    <ExperienceCards />
    <FishSpecies />
    <QuickGallery />
    <Reviews />
    <LocationMap />
    <BlogPreview />
  </main>
  <Footer />
</BaseLayout>
