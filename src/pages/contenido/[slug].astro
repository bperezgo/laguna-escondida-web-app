---
// src/pages/contenido/[slug].astro — Single blog post

import ContenidoLayout from '@/layouts/ContenidoLayout.astro';
import PostTemplate from '@/components/templates/blog/PostTemplate.astro';
import type { BlogPost } from '@/types/blog';

export async function getStaticPaths() {
  // TODO: fetch all slugs from Strapi
  // const { data } = await strapi.getBlogPosts({ populate: 'slug' });
  // return data.map(post => ({ params: { slug: post.attributes.slug } }));

  // Placeholder so the route is registered
  const placeholderPosts = [
    { slug: 'mejores-spots-pesca' },
    { slug: 'boda-perfecta-naturaleza' },
    { slug: 'receta-trucha-ajillo' },
  ];

  return placeholderPosts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

// TODO: Replace with strapi.getPostBySlug(slug)
const post: BlogPost = {
  id: '1',
  title: 'Artículo de ejemplo',
  slug: slug!,
  excerpt: 'Este artículo se cargará desde Strapi CMS una vez que esté configurado.',
  content: '<p>Contenido del artículo aquí...</p>',
  author: { id: '1', name: 'Equipo Laguna Escondida' },
  category: { id: '1', name: 'General', slug: 'general' },
  tags: [],
  publishedAt: new Date().toISOString(),
  readingTime: 5,
};

if (!post) {
  return Astro.redirect('/contenido');
}
---

<ContenidoLayout
  title={post.title}
  description={post.excerpt}
  image={post.coverImage}
  showSidebar={false}
>
  <PostTemplate post={post}>
    <div set:html={post.content} />
  </PostTemplate>
</ContenidoLayout>
