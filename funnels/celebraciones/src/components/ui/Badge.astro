---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span
  class={`inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium ${className}`}
  style="background: var(--color-primary-light); color: var(--color-primary);"
>
  <slot />
</span>
